;; Technology fingerprints for repository analysis.
;; Each entry declares how to detect a technology and which policy packs apply.
;;
;; Schema:
;;   :tech/id         — Unique keyword identifier
;;   :tech/extensions — File extensions that indicate this technology (optional)
;;   :tech/markers    — File/directory presence markers (optional)
;;     :path          — File or directory name to check
;;     :type          — :file or :directory
;;     :content       — String that must appear in the file (optional, for content-based detection)
;;   :tech/packs      — Policy pack names to apply when detected (optional)
;;   :tech/linter     — Linter integration (optional)
;;     :command       — CLI command name
;;     :args          — Arguments for lint mode (structured output)
;;     :fix-args      — Arguments for auto-fix mode (optional)
;;     :parser        — Parser keyword for output format
;;     :check-cmd     — Command to verify linter is installed (optional)
;;
;; Sorted alphabetically by :tech/id.

[;; ── Languages ──────────────────────────────────────────────────────────────

 {:tech/id         :bash
  :tech/extensions ["sh" "bash"]}

 {:tech/id         :c
  :tech/extensions ["c" "h"]}

 {:tech/id         :clojure
  :tech/extensions ["clj" "cljs" "cljc" "edn"]
  :tech/linter     {:command   "clj-kondo"
                    :args      ["--lint" "src" "--config" "{:output {:format :edn}}"]
                    :parser    :clj-kondo
                    :check-cmd ["clj-kondo" "--version"]}}

 {:tech/id         :cpp
  :tech/extensions ["cpp" "cc" "cxx" "hpp" "hxx"]}

 {:tech/id         :csharp
  :tech/extensions ["cs" "csx"]}

 {:tech/id         :clojurescript
  :tech/extensions ["cljs"]}

 {:tech/id         :coffeescript
  :tech/extensions ["coffee" "litcoffee"]}

 {:tech/id         :dart
  :tech/extensions ["dart"]}

 {:tech/id         :elixir
  :tech/extensions ["ex" "exs"]}

 {:tech/id         :erlang
  :tech/extensions ["erl" "hrl"]}

 {:tech/id         :fsharp
  :tech/extensions ["fs" "fsx" "fsi"]}

 {:tech/id         :go
  :tech/extensions ["go"]
  :tech/linter     {:command   "golangci-lint"
                    :args      ["run" "--out-format=json"]
                    :fix-args  ["run" "--fix"]
                    :parser    :golangci-lint
                    :check-cmd ["golangci-lint" "--version"]}}

 {:tech/id         :groovy
  :tech/extensions ["groovy" "gvy"]}

 {:tech/id         :haskell
  :tech/extensions ["hs" "lhs"]}

 {:tech/id         :java
  :tech/extensions ["java"]}

 {:tech/id         :javascript
  :tech/extensions ["js" "mjs" "cjs" "jsx"]
  :tech/linter     {:command   "eslint"
                    :args      ["--format=json" "."]
                    :fix-args  ["--fix" "."]
                    :parser    :eslint
                    :check-cmd ["eslint" "--version"]}}

 {:tech/id         :json
  :tech/extensions ["json"]}

 {:tech/id         :julia
  :tech/extensions ["jl"]}

 {:tech/id         :kotlin
  :tech/extensions ["kt" "kts"]}

 {:tech/id         :lua
  :tech/extensions ["lua"]}

 {:tech/id         :markdown
  :tech/extensions ["md" "markdown"]}

 {:tech/id         :nim
  :tech/extensions ["nim" "nims"]}

 {:tech/id         :objective-c
  :tech/extensions ["m" "mm"]}

 {:tech/id         :ocaml
  :tech/extensions ["ml" "mli"]}

 {:tech/id         :perl
  :tech/extensions ["pl" "pm"]}

 {:tech/id         :php
  :tech/extensions ["php"]}

 {:tech/id         :purescript
  :tech/extensions ["purs"]}

 {:tech/id         :python
  :tech/extensions ["py" "pyi"]
  :tech/linter     {:command   "ruff"
                    :args      ["check" "--output-format=json" "."]
                    :fix-args  ["check" "--fix" "."]
                    :parser    :ruff
                    :check-cmd ["ruff" "--version"]}}

 {:tech/id         :r
  :tech/extensions ["r" "R" "Rmd"]}

 {:tech/id         :racket
  :tech/extensions ["rkt"]}

 {:tech/id         :ruby
  :tech/extensions ["rb" "rake"]}

 {:tech/id         :rust
  :tech/extensions ["rs"]
  :tech/linter     {:command   "cargo"
                    :args      ["clippy" "--message-format=json" "--" "-D" "warnings"]
                    :fix-args  ["clippy" "--fix" "--allow-dirty"]
                    :parser    :clippy
                    :check-cmd ["cargo" "clippy" "--version"]}}

 {:tech/id         :scala
  :tech/extensions ["scala" "sc"]}

 {:tech/id         :scheme
  :tech/extensions ["scm" "ss"]}

 {:tech/id         :solidity
  :tech/extensions ["sol"]}

 {:tech/id         :sql
  :tech/extensions ["sql"]}

 {:tech/id         :swift
  :tech/extensions ["swift"]
  :tech/linter     {:command   "swiftlint"
                    :args      ["lint" "--reporter" "json"]
                    :fix-args  ["lint" "--fix"]
                    :parser    :swiftlint
                    :check-cmd ["swiftlint" "version"]}}

 {:tech/id         :terraform
  :tech/extensions ["tf" "tfvars"]
  :tech/packs      ["terraform-aws-1.0.0"]}

 {:tech/id         :toml
  :tech/extensions ["toml"]}

 {:tech/id         :typescript
  :tech/extensions ["ts" "tsx"]
  :tech/linter     {:command   "eslint"
                    :args      ["--format=json" "."]
                    :fix-args  ["--fix" "."]
                    :parser    :eslint
                    :check-cmd ["eslint" "--version"]}}

 {:tech/id         :v
  :tech/extensions ["v"]}

 {:tech/id         :vhdl
  :tech/extensions ["vhd" "vhdl"]}

 {:tech/id         :wasm
  :tech/extensions ["wasm" "wat"]}

 {:tech/id         :xml
  :tech/extensions ["xml" "xsl" "xslt"]}

 {:tech/id         :yaml
  :tech/extensions ["yaml" "yml"]}

 {:tech/id         :zig
  :tech/extensions ["zig"]}

