;; Tool-profile registry for progress-detector.
;;
;; Each entry declares a tool profile keyed by a qualified keyword.
;; Required fields:
;;   :detector/kind      - identifies which detector implementation handles this tool
;;   :determinism        - describes output stability across identical inputs:
;;                           :deterministic   - always identical output (hash/compile)
;;                           :stable          - same output for same state (fs-read)
;;                           :volatile        - output varies by environment/time (clock)
;;                           :nondeterministic - intentionally random/stochastic (llm)
;;
;; Optional fields:
;;   :anomaly/categories - set of anomaly categories this tool can surface
;;   :timeout-ms         - default observation timeout for this tool
;;   :config             - tool-specific detector tuning knobs

{:tool/bash
 {:detector/kind      :detector.kind/shell
  :determinism        :volatile
  :anomaly/categories #{:anomaly.category/stall
                        :anomaly.category/loop
                        :anomaly.category/error}
  :timeout-ms         120000}

 :tool/write
 {:detector/kind      :detector.kind/fs-mutation
  :determinism        :stable
  :anomaly/categories #{:anomaly.category/stall
                        :anomaly.category/regression}
  :timeout-ms         30000}

 :tool/edit
 {:detector/kind      :detector.kind/fs-mutation
  :determinism        :stable
  :anomaly/categories #{:anomaly.category/stall
                        :anomaly.category/regression}
  :timeout-ms         30000}

 :tool/read
 {:detector/kind      :detector.kind/fs-read
  :determinism        :stable
  :anomaly/categories #{:anomaly.category/loop}
  :timeout-ms         10000}

 :tool/glob
 {:detector/kind      :detector.kind/fs-read
  :determinism        :stable
  :anomaly/categories #{:anomaly.category/loop}
  :timeout-ms         10000}

 :tool/grep
 {:detector/kind      :detector.kind/fs-read
  :determinism        :stable
  :anomaly/categories #{:anomaly.category/loop}
  :timeout-ms         10000}

 :tool/agent
 {:detector/kind      :detector.kind/llm
  :determinism        :nondeterministic
  :anomaly/categories #{:anomaly.category/stall
                        :anomaly.category/loop
                        :anomaly.category/cost-spike}
  :timeout-ms         600000}

 :tool/web-fetch
 {:detector/kind      :detector.kind/network
  :determinism        :volatile
  :anomaly/categories #{:anomaly.category/stall
                        :anomaly.category/error}
  :timeout-ms         30000}

 :tool/web-search
 {:detector/kind      :detector.kind/network
  :determinism        :volatile
  :anomaly/categories #{:anomaly.category/stall
                        :anomaly.category/error}
  :timeout-ms         30000}

 :tool/todo-write
 {:detector/kind      :detector.kind/state-mutation
  :determinism        :deterministic
  :anomaly/categories #{:anomaly.category/loop
                        :anomaly.category/regression}
  :timeout-ms         5000}

 :tool/notebook-edit
 {:detector/kind      :detector.kind/fs-mutation
  :determinism        :stable
  :anomaly/categories #{:anomaly.category/stall
                        :anomaly.category/regression}
  :timeout-ms         30000}}
