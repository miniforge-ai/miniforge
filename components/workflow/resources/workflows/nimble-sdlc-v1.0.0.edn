;; Nimble SDLC Workflow v1.0.0 (Interceptor-based)
;; ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
;;
;; Nimble-inspired workflow: waterfall upfront (explore + plan), agile execution.
;; Explore phase loads existing files before planning to prevent redundant work.
;;
;; Pipeline: explore → plan → implement → verify → review → release → done

{:workflow/id :nimble-sdlc
 :workflow/version "1.0.0"
 :workflow/name "Nimble SDLC Workflow"
 :workflow/description "Waterfall upfront (explore + plan), agile execution. Explore phase
                        loads existing files before planning to prevent redundant work."

 :workflow/pipeline
 [;; Exploration phase - deterministic file loading, no LLM
  {:phase :explore}

  ;; Planning phase - receives explore results for informed planning
  {:phase :plan}

  ;; Implementation phase - override to add policy gate
  {:phase :implement
   :gates [:syntax :lint :no-secrets]
   :budget {:tokens 50000}}

  ;; Verification phase - runs tests, retries implementation on failure
  {:phase :verify
   :on-fail :implement}

  ;; Review phase - quality and approval checks
  {:phase :review
   :on-fail :implement}

  ;; Release phase - creates PR
  {:phase :release}

  ;; Terminal phase
  {:phase :done}]

 :workflow/config
 {:max-tokens 150000
  :max-iterations 50
  :failure-strategy :retry}}
