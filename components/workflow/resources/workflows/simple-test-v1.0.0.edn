;; Simple Test Workflow v1.0.0
;; ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
;;
;; Minimal workflow for testing the configurable workflow system.
;; Contains only essential phases: plan -> implement -> done.
;;
;; Purpose: Unit testing, integration testing, and workflow system validation.
;; This workflow is designed to complete quickly with mock LLMs.

{:workflow/id :simple-test-v1
 :workflow/version "1.0.0"
 :workflow/name "Simple Test Workflow"
 :workflow/description
 "Minimal workflow with plan -> implement -> done phases.
  Designed for testing the configurable workflow execution engine."

 :workflow/created-at #inst "2026-01-21T00:00:00.000-00:00"
 :workflow/task-types [:test :demo :tutorial]
 :workflow/entry :plan

 :workflow/phases
 [{:phase/id :plan
   :phase/name "Planning"
   :phase/description "Create implementation plan from requirements"
   :phase/agent :planner
   :phase/actions [:analyze-requirements :create-plan]
   :phase/inner-loop
   {:max-iterations 3
    :validation-steps [:plan-complete]
    :repair-strategy :refine-plan}
   :phase/gates []  ; No gates for simplicity
   :phase/budget {:tokens 5000 :time-seconds 60 :iterations 3}
   :phase/next [{:target :implement}]
   :phase/metrics [:plan-tasks-count :plan-complexity]}

  {:phase/id :implement
   :phase/name "Implementation"
   :phase/description "Generate code from plan"
   :phase/agent :implementer
   :phase/actions [:write-code]
   :phase/inner-loop
   {:max-iterations 5
    :validation-steps [:syntax-valid]
    :repair-strategy :fix-syntax-errors}
   :phase/gates [:syntax-valid]  ; Single gate
   :phase/budget {:tokens 10000 :time-seconds 120 :iterations 5}
   :phase/next [{:target :done}]
   :phase/metrics [:files-created :lines-of-code]}

  {:phase/id :done
   :phase/name "Done"
   :phase/description "Workflow completion marker"
   :phase/agent :none  ; No agent - just marks completion
   :phase/actions []
   :phase/inner-loop
   {:max-iterations 1
    :validation-steps []
    :repair-strategy :none}
   :phase/gates []
   :phase/budget {:tokens 0 :time-seconds 5 :iterations 1}
   :phase/next []  ; No transitions - terminal phase
   :phase/metrics []}]

 :workflow/config
 {:parallel-phases []
  :failure-strategy :fail-fast  ; Stop immediately on failure for testing
  :max-total-iterations 20
  :max-total-time-seconds 300  ; 5 minutes max
  :max-total-tokens 20000}

 :workflow/metrics
 {:success-rate nil
  :avg-iterations nil
  :avg-time-seconds nil
  :avg-tokens-used nil}}
