;; Simple test workflow v1.0.0
;; Minimal workflow for testing: Plan → Implement → Done

{:workflow/id :simple-test-v1
 :workflow/version "1.0.0"
 :workflow/name "Simple Test Workflow"
 :workflow/description "Simple 3-phase workflow for testing"
 :workflow/created-at #inst "2026-01-21T00:00:00.000-00:00"
 :workflow/task-types [:test]

 :workflow/phases
 [{:phase/id :plan
   :phase/name "Planning"
   :phase/agent :planner
   :phase/actions [:create-plan]
   :phase/inner-loop
   {:max-iterations 2
    :validation-steps [:plan-complete]
    :repair-strategy :adjust-plan}
   :phase/gates [:plan-complete]
   :phase/budget {:tokens 3000 :time-seconds 60 :iterations 2}
   :phase/next [{:target :implement}]
   :phase/metrics [:planning-time]}

  {:phase/id :implement
   :phase/name "Implementation"
   :phase/agent :implementer
   :phase/actions [:write-code]
   :phase/inner-loop
   {:max-iterations 3
    :validation-steps [:code-complete]
    :repair-strategy :fix-errors}
   :phase/gates [:code-complete]
   :phase/budget {:tokens 5000 :time-seconds 120 :iterations 3}
   :phase/next [{:target :done}]
   :phase/metrics [:implementation-time]}

  {:phase/id :done
   :phase/name "Complete"
   :phase/agent :none
   :phase/actions [:finalize]
   :phase/inner-loop
   {:max-iterations 1
    :validation-steps [:complete]
    :repair-strategy :none}
   :phase/budget {:tokens 100 :time-seconds 1 :iterations 1}
   :phase/next []
   :phase/metrics [:total-time]}]

 :workflow/config
 {:parallel-phases []
  :failure-strategy :retry
  :max-total-iterations 10
  :max-total-time-seconds 300
  :max-total-tokens 10000}

 :workflow/metrics
 {:success-rate nil
  :avg-iterations nil
  :avg-time-seconds nil
  :avg-tokens-used nil
  :avg-repair-cycles nil
  :test-coverage-achieved nil
  :bugs-caught-in-review nil
  :bugs-caught-in-ci nil
  :bugs-in-production nil}}
