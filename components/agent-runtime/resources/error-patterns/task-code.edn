   :description "Namespace resolution error"}
  {:regex "No such file or directory"
   :description "File not found error"}
  {:regex "Unexpected token at line \\d+"
   :description "Parsing error"}
  {:regex "Parse error: missing closing parenthesis"
   :description "Parenthesis mismatch"}
  {:regex "Syntax error"
   :description "General syntax error"}
  {:regex "Parse error"
   :description "General parse error"}
  {:regex "Compilation error"
   :description "General compilation error"}
  {:regex "Test failed"
   :description "Test failure"}]}
