;; Miniforge Engineering Standards pack — compiled from .standards/*.mdc files.
;;
;; This file is the output of the ETL task (bb standards:pack) which reads
;; .standards/*.mdc files and compiles them into policy-pack rules using
;; ai.miniforge.policy-pack.mdc-compiler/compile-standards-pack.
;;
;; The manifest shape below is the canonical template. The ETL replaces
;; :pack/rules with compiled rule maps and populates :pack/categories.
;;
;; Loaded from the classpath by ai.miniforge.phase.agent-behavior.
;;
;; Rule structure per compiled rule:
;;   :rule/id                keyword    ; :std/<filename-slug>
;;   :rule/title             string     ; from description frontmatter
;;   :rule/description       string     ; "Engineering standard (<dewey>): <title>"
;;   :rule/severity          :info      ; always :info (guidance, not violation)
;;   :rule/category          string     ; Dewey code from frontmatter
;;   :rule/applies-to        map        ; {:phases #{...} :file-globs [...]}
;;   :rule/detection         map        ; {:type :custom} always
;;   :rule/enforcement       map        ; {:action :audit :message "Standard: <title>"}
;;   :rule/agent-behavior    string?    ; concise directive for prompt injection
;;   :rule/knowledge-content string?    ; full MDC body text
;;   :rule/always-inject?    boolean?   ; true when alwaysApply: true in frontmatter

{:pack/id          "miniforge/standards"
 :pack/name        "Miniforge Engineering Standards"
 :pack/version     "2026.03"
 :pack/description "Shared engineering standards compiled from .standards/ MDC files. Generated by bb standards:pack."
 :pack/author      "miniforge.ai"
 :pack/license     "Apache-2.0"
 :pack/trust-level :trusted
 :pack/authority   :authority/instruction

 :pack/categories
 [{:category/id    "foundations"
   :category/name  "Foundations & Core Principles"
   :category/rules [:std/code-quality
                    :std/index
                    :std/localization
                    :std/result-handling
                    :std/simple-made-easy
                    :std/specification-standards
                    :std/stratified-design
                    :std/validation-boundaries]}
  {:category/id    "languages"
   :category/name  "Languages"
   :category/rules [:std/clojure :std/python]}
  {:category/id    "frameworks"
   :category/name  "Frameworks & Platforms"
   :category/rules [:std/kubernetes :std/polylith]}
  {:category/id    "testing"
   :category/name  "Testing & Quality"
   :category/rules [:std/standards]}
  {:category/id    "workflows"
   :category/name  "Workflows & Processes"
   :category/rules [:std/datever
                    :std/git-branch-management
                    :std/git-worktrees
                    :std/pr-documentation
                    :std/pr-layering
                    :std/pre-commit-discipline]}
  {:category/id    "project"
   :category/name  "Project-Specific"
   :category/rules [:std/header-copyright]}
  {:category/id    "meta"
   :category/name  "Meta & Templates"
   :category/rules [:std/rule-format]}]

 :pack/rules []

 :pack/created-at #inst "2026-03-29T00:00:00.000Z"
 :pack/updated-at #inst "2026-03-29T00:00:00.000Z"}
