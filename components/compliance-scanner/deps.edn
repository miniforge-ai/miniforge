{:paths ["src" "resources"]
 :deps {ai.miniforge/coerce     {:local/root "../coerce"}
        ai.miniforge/logging    {:local/root "../logging"}
        ai.miniforge/messages   {:local/root "../messages"}
        ai.miniforge/repo-index {:local/root "../repo-index"}
