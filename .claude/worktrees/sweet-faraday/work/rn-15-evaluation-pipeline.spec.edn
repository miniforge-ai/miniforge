;; Reliability Nines — RN-15: Evaluation Pipeline
;; Tier 5 (Eval & Intelligence) — depends on RN-04, RN-06
;; Blocks: RN-17

{:spec/title "RN-15: Evaluation Pipeline (Golden Sets, Replay, Shadow, Canary)"
 :version "1.0.0"
 :type :feature
 :priority :medium

 :spec/description
 "Create a new evaluation Polylith component implementing the evaluation
  pipeline from N1 §3.3.3. Extend the existing replay.clj (state
  reconstruction) into full workflow re-execution. Add shadow mode
  (parallel comparison) and canary deployment (staged rollout).

  Current state: replay.clj reconstructs state from events, verify-determinism
  checks replay consistency. Not re-execution.
  Target state: Full evaluation pipeline with golden sets and 3 execution modes."

 :spec/intent
 {:type :feature
  :scope ["components/evaluation (NEW)"
          "components/workflow (extend replay.clj)"
          "components/evidence-bundle (golden-set artifacts)"]}

 :normative-refs
 {:primary "N1 §3.3.3 — Evaluation Pipeline"
  :secondary ["N6 §3.1.1 — Golden Set / Eval Run artifacts"]}

 :gap-analysis-ref "gap-analysis-reliability-nines.md #7, #18"
 :dag/id :rn-15
 :dag/depends-on [:rn-04 :rn-06]
 :dag/blocks [:rn-17]

 :implementation
 {:step-1-golden-sets
  {:title "Create golden set artifact management"
   :files-to-create
   ["components/evaluation/src/ai/miniforge/evaluation/interface.clj"
    "components/evaluation/src/ai/miniforge/evaluation/core.clj"
    "components/evaluation/src/ai/miniforge/evaluation/golden_set.clj"
    "components/evaluation/src/ai/miniforge/evaluation/schema.clj"]
   :changes
   ["Golden set CRUD: create, list, add-entry, remove-entry"
    "Golden set artifact schema (N6 §3.1.1)"
    "Entry schema: workflow-spec, expected-outcome, pass-criteria"
    "Versioning: golden sets are immutable snapshots"]}

  :step-2-replay-mode
  {:title "Extend replay into re-execution"
   :files-to-modify
   ["components/workflow/src/ai/miniforge/workflow/replay.clj"]
   :changes
   ["replay-execute: re-run workflow from spec (not just reconstruct state)"
    "Compare actual outcome against golden set expected outcome"
    "Produce eval-run-result artifact with per-entry pass/fail"]}

  :step-3-shadow-mode
  {:title "Implement shadow mode"
   :files-to-create
   ["components/evaluation/src/ai/miniforge/evaluation/shadow.clj"]
   :changes
   ["Run two workflow versions in parallel"
    "Compare outputs: exact match, structural match, semantic match"
    "Produce comparison report as eval-run-result artifact"
    "Shadow runs MUST NOT have side effects"]}

  :step-4-canary
  {:title "Implement canary deployment mode"
   :files-to-create
   ["components/evaluation/src/ai/miniforge/evaluation/canary.clj"]
   :changes
   ["Staged rollout: run new version on X% of workflows"
    "Compare SLI values between canary and baseline"
    "Auto-rollback if canary SLIs degrade"
    "Promote canary to baseline on success"]}

  :step-5-artifacts
  {:title "Register golden-set and eval-run-result artifact types"
   :files-to-modify
   ["components/evidence-bundle/src/ai/miniforge/evidence_bundle/schema.clj"
    "components/artifact/src/ai/miniforge/artifact/core.clj"]
   :changes
   ["Add :golden-set artifact type schema"
    "Add :eval-run-result artifact type schema"
    "Register in artifact type dispatch"]}}

 :spec/constraints
 ["Shadow mode MUST NOT produce side effects"
  "Golden sets MUST be immutable (create new version, don't mutate)"
  "Canary auto-rollback MUST use SLI comparison (not just errors)"
  "Eval results MUST be stored as N6 evidence artifacts"
  "Follow Polylith interface-only deps"
  "Babashka compatible"]

 :testing-strategy
 {:unit-tests
  ["Golden set CRUD operations"
   "Replay re-execution produces eval-run-result"
   "Per-entry pass/fail evaluation"
   "Shadow comparison: exact, structural, semantic"
   "Canary percentage routing"]
  :integration-tests
  ["Golden set → replay → eval-run-result artifact produced"
   "Shadow mode: two versions compared, no side effects"]}

 :spec/acceptance-criteria
 [{:criterion "Golden set management"
   :verification "Create, version, and query golden sets"}
  {:criterion "Replay re-execution"
   :verification "Workflow re-run produces pass/fail against golden set"}
  {:criterion "Shadow mode comparison"
   :verification "Two versions compared without side effects"}
  {:criterion "Canary deployment"
   :verification "Staged rollout with SLI comparison"}
  {:criterion "Eval artifacts"
   :verification "Golden sets and eval results stored as N6 artifacts"}]

 :estimated-effort "1-2 weeks"
 :workflow/type :standard-sdlc
 :workflow/version "2.0.0"}
