;; Reliability Nines — RN-08: Safe-Mode Posture
;; Tier 3 (Governance) — depends on RN-04, RN-05, RN-07
;; No downstream blocks (terminal in governance tier)

{:spec/title "RN-08: Safe-Mode Posture with Triggers, Behavior, and Exit Protocol"
 :version "1.0.0"
 :type :feature
 :priority :high

 :spec/description
 "Extend the existing emergency-stop control action into a full safe-mode
  posture per N8 §3.4. Add trigger detection (error budget exhaustion,
  cascade detection, external signal), behavior enforcement (autonomy
  demotion to A0, workflow queuing), and exit protocol (manual + cooldown).

  Current state: control.clj has emergency-stop action with RBAC.
  Target state: Full safe-mode state machine with auto-triggers and exit."

 :spec/intent
 {:type :feature
  :scope ["components/event-stream/src/ai/miniforge/event_stream/control.clj"
          "components/reliability-metrics (extend)"
          "components/autonomy (extend)"]}

 :normative-refs
 {:primary "N8 §3.4 — Safe-Mode Posture"
  :secondary ["N8 §3.4.1 — Triggers"
              "N8 §3.4.2 — Behavior"
              "N8 §3.4.3 — Exit Protocol"
              "N8 §3.4.4 — State and Events"]}

 :gap-analysis-ref "gap-analysis-reliability-nines.md #13"
 :dag/id :rn-08
 :dag/depends-on [:rn-04 :rn-05 :rn-07]
 :dag/blocks []

 :current-state
 {:control "event-stream/control.clj — authorize-action, execute-control-action!"
  :emergency-stop "Admin can :emergency-stop (action exists)"
  :safe-mode "No safe-mode state, triggers, or exit protocol"
  :completion "10%"}

 :target-state
 {:triggers
  ["Error budget exhausted for :critical tier (auto)"
   "emergency-stop control action (manual)"
   "Cascade detection: ≥3 concurrent workflow failures within 60s (auto)"
   "External signal: API endpoint for operator (manual)"]
  :behavior
  ["Demote all autonomy to A0 via autonomy component"
   "Queue new workflow submissions (don't reject)"
   "Pause in-flight workflows at next gate boundary"
   "Elevate all alerts to :critical"
   "Disable auto-repair"
   "Emit safe-mode/entered event"]
  :exit
  ["Requires manual operator action (no auto-recovery)"
   "Cooldown period (configurable, default 5 min)"
   "Operator must acknowledge trigger resolution"
   "Restore previous autonomy levels"
   "Resume queued workflows in submission order"
   "Emit safe-mode/exited event"]}

 :implementation
 {:step-1-state
  {:title "Add safe-mode state management"
   :files-to-modify
   ["components/event-stream/src/ai/miniforge/event_stream/control.clj"]
   :changes
   ["Add safe-mode-state atom: {:active? false :entered-at nil :trigger nil :cooldown-ms 300000}"
    "enter-safe-mode! function"
    "exit-safe-mode! function with cooldown check"
    "safe-mode? query function"]}

  :step-2-triggers
  {:title "Wire auto-triggers"
   :files-to-modify
   ["components/reliability-metrics/src/ai/miniforge/reliability_metrics/degradation.clj"]
   :changes
   ["On :safe-mode degradation transition → call enter-safe-mode!"
    "Cascade detector: track recent failures, trigger if ≥3 in 60s"
    "Wire emergency-stop control action → enter-safe-mode!"]}

  :step-3-behavior
  {:title "Enforce safe-mode behavior"
   :files-to-modify
   ["components/workflow/src/ai/miniforge/workflow/context.clj"
    "components/dag-executor/src/ai/miniforge/dag_executor/state.clj"]
   :changes
   ["Check safe-mode? before starting workflow"
    "In safe-mode: add to queue instead of starting"
    "Pause in-flight workflows at next gate"
    "Demote autonomy via autonomy component"]}

  :step-4-events
  {:title "Emit safe-mode events"
   :files-to-modify
   ["components/event-stream/src/ai/miniforge/event_stream/core.clj"]
   :changes
   ["Add safe-mode/entered event constructor"
    "Add safe-mode/exited event constructor"
    "Emit on state transitions"]}}

 :spec/constraints
 ["Safe-mode exit MUST require manual operator action"
  "Safe-mode MUST NOT reject workflows — queue them"
  "Cooldown period MUST elapse before exit permitted"
  "Emergency-stop MUST work even when SLI engine is unavailable"
  "Follow Polylith interface-only deps"]

 :testing-strategy
 {:unit-tests
  ["Enter safe-mode: state transitions correctly"
   "Exit safe-mode: cooldown enforced"
   "Exit safe-mode: premature exit rejected"
   "Cascade detection: 3 failures in 60s triggers safe-mode"
   "Cascade detection: 2 failures does not trigger"]
  :integration-tests
  ["Error budget exhaustion → safe-mode → workflows queued"
   "Emergency-stop → safe-mode → manual exit → workflows resume"]}

 :spec/acceptance-criteria
 [{:criterion "4 triggers activate safe-mode"
   :verification "Each trigger tested independently"}
  {:criterion "Autonomy demoted to A0 in safe-mode"
   :verification "Workflow autonomy queries return A0 during safe-mode"}
  {:criterion "Workflows queued, not rejected"
   :verification "Submissions during safe-mode recoverable after exit"}
  {:criterion "Manual exit with cooldown"
   :verification "Auto-exit prevented, premature exit rejected"}]

 :estimated-effort "3-5 days"
 :workflow/type :standard-sdlc
 :workflow/version "2.0.0"}
