;; Reliability Nines — RN-01: Canonical Failure Taxonomy
;; Tier 1 (Foundation) — no dependencies
;; Blocks: RN-04, RN-05, RN-06, RN-07, RN-08, RN-10

{:spec/title "RN-01: Expand Failure Taxonomy to 10-Class Canonical Enum"
 :version "1.0.0"
 :type :enhancement
 :priority :critical

 :spec/description
 "Expand the existing 3-class error classifier (agent-backend, task-code, external)
  to the 10-class canonical failure taxonomy defined in N1 §5.3.3. Wire the
  :failure/class keyword into all failure event constructors per N3.

  This is the foundation for the entire reliability nines stack — SLIs, error
  budgets, degradation modes, and safe-mode all depend on structured failure
  classification.

  Current state: error_classifier/core.clj has classify-error returning 3 classes.
  Target state: 10-class enum with every failure event carrying :failure/class."

 :spec/intent
 {:type :feature
  :scope ["components/agent-runtime/src/ai/miniforge/agent_runtime/error_classifier"
          "components/event-stream/src/ai/miniforge/event_stream/schema.clj"
          "components/event-stream/src/ai/miniforge/event_stream/core.clj"]}

 :normative-refs
 {:primary "N1 §5.3.3 — Canonical Failure Taxonomy"
  :secondary ["N3 §3.17 — failure/class on failure events"
              "N6 §2.6 — :outcome/failure-class in evidence"]}

 :gap-analysis-ref "gap-analysis-reliability-nines.md #1"
 :dag/id :rn-01
 :dag/depends-on []
 :dag/blocks [:rn-04 :rn-05 :rn-06 :rn-07 :rn-08 :rn-10]

 :current-state
 {:classifier "error_classifier/core.clj — classify-error returns 3 classes"
  :classes [:agent-backend :task-code :external]
  :events "WorkflowFailed has :workflow/failure-reason (string), no :failure/class"
  :completion "20%"}

 :target-state
 {:classes [:failure.class/agent-error
            :failure.class/task-code
            :failure.class/tool-error
            :failure.class/external
            :failure.class/policy
            :failure.class/resource
            :failure.class/timeout
            :failure.class/concurrency
            :failure.class/data-integrity
            :failure.class/unknown]
  :events "All 5 failure events carry :failure/class keyword"
  :evidence "Outcome evidence includes :outcome/failure-class"}

 :implementation
 {:step-1-expand-classifier
  {:title "Expand error classifier to 10 classes"
   :files-to-modify
   ["components/agent-runtime/src/ai/miniforge/agent_runtime/error_classifier/core.clj"
    "components/agent-runtime/src/ai/miniforge/agent_runtime/error_classifier/patterns.clj"]
   :changes
   ["Add 7 new failure classes to classification logic"
    "Add patterns for: tool-error, policy, resource, timeout, concurrency, data-integrity"
    "Map existing :agent-backend → :failure.class/agent-error"
    "Map existing :task-code → :failure.class/task-code"
    "Map existing :external → :failure.class/external"
    "Default unmatched → :failure.class/unknown"]}

  :step-2-event-schemas
  {:title "Add :failure/class to failure event schemas"
   :files-to-modify
   ["components/event-stream/src/ai/miniforge/event_stream/schema.clj"]
   :changes
   ["Add :failure/class keyword to WorkflowFailed schema"
    "Add :failure/class keyword to AgentFailed schema"
    "Add :failure/class keyword to EtlFailed schema"
    "Add :failure/class keyword to PackRunFailed schema"
    "Add :failure/class keyword to ChainEdgeFailed schema"
    "Define FailureClass enum schema for validation"]}

  :step-3-event-constructors
  {:title "Wire failure class into event constructors"
   :files-to-modify
   ["components/event-stream/src/ai/miniforge/event_stream/core.clj"]
   :changes
   ["Update workflow-failed constructor to accept and emit :failure/class"
    "Update agent-failed constructor"
    "Update etl-failed constructor"
    "Update pack-run-failed constructor"
    "Update chain-edge-failed constructor"
    "Ensure :failure/class defaults to :failure.class/unknown if not provided"]}

  :step-4-emission-sites
  {:title "Wire classifier into all failure emission sites"
   :files-to-modify
   ["components/dag-executor (workflow failure emission)"
    "components/agent-runtime (agent failure emission)"
    "components/workflow (etl/pack-run/chain-edge failure emission)"]
   :changes
   ["Call classify-error at each failure site"
    "Pass classified :failure/class to event constructor"]}}

 :spec/constraints
 ["Backward compatible: existing :workflow/failure-reason string preserved"
  "New :failure/class keyword added alongside, not replacing"
  "Classification MUST be deterministic for same error"
  "Unknown errors MUST classify as :failure.class/unknown, never nil"
  "Follow Polylith interface-only deps"]

 :testing-strategy
 {:unit-tests
  ["10-class pattern matching coverage"
   "Backward compat: old 3-class callers still work"
   "Unknown fallback for unrecognized errors"
   "Each failure event constructor includes :failure/class"]
  :integration-tests
  ["End-to-end: trigger workflow failure → verify :failure/class in event"
   "Verify Malli schema validation passes for all 10 classes"]}

 :spec/acceptance-criteria
 [{:criterion "Classifier returns one of 10 canonical classes"
   :verification "Unit tests cover all 10 classes with example errors"}
  {:criterion "All 5 failure events carry :failure/class"
   :verification "Malli schema validation enforces :failure/class keyword"}
  {:criterion "Backward compatible with existing error handling"
   :verification "Existing tests pass without modification"}
  {:criterion "Default to :failure.class/unknown"
   :verification "Unrecognized error classified as unknown, not nil"}]

 :estimated-effort "1-2 days"
 :workflow/type :standard-sdlc
 :workflow/version "2.0.0"}
