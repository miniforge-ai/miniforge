{:spec/title "Web Dashboard Phase 1: Design System & Component Library"
 :version "1.0.0"
 :parent-spec "work/web-dashboard-v2.edn"
 :phase 1
 :estimated-size "~350 lines"

 :spec/description
 "Build the foundation for the web dashboard: CSS design system and reusable
  Hiccup component library. This provides the building blocks for all 9 views
  (dashboard, PR fleet, workflow monitoring, etc.).

  Focus: Clean, maintainable, aesthetic components that capture the terminal
  aesthetic + Tableau-inspired density."

 :spec/intent
 {:type :foundation
  :scope ["CSS design system with variables"
          "Reusable Hiccup component library"
          "Terminal aesthetic + modern web polish"]

  :context
   {:current-state
    ["Basic web dashboard exists with 5 N5 views"
     "CSS is in components/web-dashboard/resources/public/css/app.css"
     "Views use inline hiccup without reusable components"
     "No design system or consistent styling"]

    :design-direction
    ["Terminal aesthetic (monospace, dark theme, box drawing)"
     "Tableau-inspired density (information-rich, visual)"
     "Modern control plane look (clean, professional)"
     "Accessibility (good contrast, readable fonts)"]

    :references
    ["work/web-dashboard-designs.md - Full UI mockups"
     "work/web-dashboard-v2.edn - Complete spec (9 phases)"
     "components/web-dashboard/src/ai/miniforge/web_dashboard/views.clj - Current views"
     "components/web-dashboard/resources/public/css/app.css - Current CSS"]}}

 :spec/constraints
 ["Each component ≤30 lines of code"
  "Components are pure functions (no side effects, no state)"
  "CSS uses variables for all design tokens"
  "Zero linting errors (clj-kondo)"
  "File must be ≤400 lines total (Rule 720)"
  "Stratification: ≤3 layers per file (Rule 210)"]

 :design-system
 {:colors
  {:background "#1e1e1e"
   :surface "#2d2d2d"
   :surface-elevated "#353535"
   :border "#3d3d3d"
   :text "#d4d4d4"
   :text-muted "#888888"
   :primary "#00d4ff"
   :success "#4ec9b0"
   :warning "#dcdcaa"
   :error "#f48771"
   :risk-high "#f48771"
   :risk-medium "#dcdcaa"
   :risk-low "#4ec9b0"}

  :typography
  {:font-family "'SF Mono', 'JetBrains Mono', 'Menlo', monospace"
   :font-size-base "14px"
   :font-size-small "12px"
   :font-size-large "16px"
   :line-height "1.6"}

  :spacing
  {:xs "0.25rem"  ; 4px
   :sm "0.5rem"   ; 8px
   :md "1rem"     ; 16px
   :lg "1.5rem"   ; 24px
   :xl "2rem"}    ; 32px

  :borders
  {:radius-sm "4px"
   :radius-md "6px"
   :width "1px"}

  :shadows
  {:sm "0 1px 2px rgba(0,0,0,0.3)"
   :md "0 2px 4px rgba(0,0,0,0.4)"
   :lg "0 4px 8px rgba(0,0,0,0.5)"}}

 :components
 {:primitives
  "Layer 0: Basic UI elements (buttons, badges, cards, inputs)

   Each component should be a pure function that returns hiccup data structure.
   No side effects, no state, no external dependencies (except clojure.string).

   Component signature pattern:
   (defn component-name
     \"Docstring explaining purpose and options.\"
     [content & [{:keys [variant size class] :as opts}]]
     [:element {:class (build-class opts)} content])"

  :required-primitives
  [{:name "button"
    :signature "(button label & [opts])"
    :variants [:primary :secondary :danger :ghost]
    :options {:size [:sm :md :lg]
              :disabled boolean
              :class string}
    :example
    "(button \"Approve\" {:variant :primary :size :md})
     ;=> [:button.btn.btn-primary.btn-md \"Approve\"]"}

   {:name "badge"
    :signature "(badge label & [opts])"
    :variants [:success :warning :error :info :neutral]
    :options {:icon string
              :class string}
    :example
    "(badge \"HIGH\" {:variant :error :icon \"🔴\"})
     ;=> [:span.badge.badge-error [:span.badge-icon \"🔴\"] \"HIGH\"]"}

   {:name "card"
    :signature "(card content & [opts])"
    :options {:title string
              :footer hiccup
              :class string}
    :example
    "(card \"Content here\" {:title \"Card Title\"})
     ;=> [:div.card [:div.card-header \"Card Title\"]
                    [:div.card-body \"Content here\"]]"}

   {:name "stat-card"
    :signature "(stat-card value label & [opts])"
    :description "Metric card for dashboard (large number + label)"
    :options {:trend [:up :down :neutral]
              :class string}
    :example
    "(stat-card \"47\" \"PRs\" {:trend :up})
     ;=> [:div.stat-card [:div.stat-value \"47\"]
                         [:div.stat-label \"PRs\"]
                         [:div.stat-trend.up \"↑\"]]"}

   {:name "progress-bar"
    :signature "(progress-bar percent & [opts])"
    :options {:show-label boolean
              :variant [:primary :success :warning :error]
              :class string}
    :example
    "(progress-bar 70 {:show-label true})
     ;=> [:div.progress [:div.progress-fill {:style \"width: 70%\"}]
                        [:div.progress-label \"70%\"]]"}

   {:name "status-dot"
    :signature "(status-dot status)"
    :statuses [:running :completed :failed :pending :blocked]
    :example
    "(status-dot :running)
     ;=> [:span.status-dot.running \"●\"]"}

   {:name "icon"
    :signature "(icon name & [opts])"
    :description "Unicode icon with optional label"
    :icons {:check "✓" :cross "✗" :clock "⏳" :dot "●" :circle "○"
            :arrow-right "→" :arrow-down "▼" :arrow-right-small "▸"}
    :example
    "(icon :check {:class \"success\"})
     ;=> [:span.icon.success \"✓\"]"}]

  :layouts
  "Layer 1: Layout components (page, panel, grid, split)"

  :required-layouts
  [{:name "page"
    :signature "(page content & [opts])"
    :description "Main page wrapper with header, nav, content, footer"
    :options {:title string
              :nav hiccup
              :actions hiccup
              :class string}
    :structure
    "[:div.page
      [:header.page-header ...]
      [:div.page-body
       [:nav.page-nav ...]
       [:main.page-content content]
       [:aside.page-actions ...]]
      [:footer.page-footer ...]]"}

   {:name "panel"
    :signature "(panel content & [opts])"
    :description "Generic content container with optional header/footer"
    :options {:title string
              :actions hiccup
              :footer hiccup
              :class string}}

   {:name "grid"
    :signature "(grid items & [opts])"
    :description "Responsive multi-column grid"
    :options {:columns integer
              :gap [:xs :sm :md :lg :xl]
              :class string}}

   {:name "split"
    :signature "(split left right & [opts])"
    :description "2-column layout with adjustable split"
    :options {:ratio [integer integer] ; e.g., [1 2] = 1/3 + 2/3
              :direction [:horizontal :vertical]
              :class string}}]

  :data-display
  "Layer 2: Data-focused components (table, tree, timeline)"

  :required-data-display
  [{:name "table"
    :signature "(table rows & [opts])"
    :description "Sortable, filterable table"
    :options {:columns [{:key keyword :label string :align [:left :center :right]}]
              :sortable boolean
              :selectable boolean
              :class string}
    :example
    "(table [{:id 1 :name \"Alice\" :status :active}
             {:id 2 :name \"Bob\" :status :pending}]
            {:columns [{:key :name :label \"Name\"}
                       {:key :status :label \"Status\"}]
             :sortable true})"}

   {:name "tree"
    :signature "(tree nodes & [opts])"
    :description "Expandable hierarchical tree"
    :options {:expanded #{id}  ; set of expanded node IDs
              :selected id
              :icon-fn function  ; (fn [node] icon-char)
              :class string}
    :structure
    "Each node: {:id any :label string :children [nodes]}"}

   {:name "timeline"
    :signature "(timeline events & [opts])"
    :description "Chronological event list with timestamps"
    :options {:show-relative-time boolean
              :class string}
    :structure
    "Each event: {:timestamp inst :label string :icon string}"}]}

 :implementation
 {:files-to-create
  [{:path "components/web-dashboard/resources/public/css/design-system.css"
    :purpose "CSS variables, reset, base styles, utility classes"
    :size "~150 lines"
    :structure
    "/* 1. CSS Variables (colors, spacing, typography, etc.) */
     :root { --color-background: #1e1e1e; ... }

     /* 2. Reset & Base Styles */
     *, *::before, *::after { box-sizing: border-box; }
     body { font-family: var(--font-family); ... }

     /* 3. Utility Classes */
     .flex { display: flex; }
     .gap-sm { gap: var(--spacing-sm); }
     .text-muted { color: var(--color-text-muted); }
     ..."}

   {:path "components/web-dashboard/src/ai/miniforge/web_dashboard/components.clj"
    :purpose "Reusable Hiccup component library"
    :size "~200 lines"
    :structure
    ";; Layer 0: Primitives
     (defn button [...] ...)
     (defn badge [...] ...)
     (defn card [...] ...)
     (defn stat-card [...] ...)
     (defn progress-bar [...] ...)
     (defn status-dot [...] ...)
     (defn icon [...] ...)

     ;; Layer 1: Layouts
     (defn page [...] ...)
     (defn panel [...] ...)
     (defn grid [...] ...)
     (defn split [...] ...)

     ;; Layer 2: Data Display
     (defn table [...] ...)
     (defn tree [...] ...)
     (defn timeline [...] ...)

     ;; Note: Each function should be ≤30 lines"}]

  :files-to-modify
  [{:path "components/web-dashboard/resources/public/css/app.css"
    :changes ["Add @import \"design-system.css\"; at top"
              "Keep existing component-specific styles"
              "Remove duplicate variables (now in design-system.css)"]}]

  :aesthetic-guidance
  "Key aesthetic principles:
   - Terminal feel: Use monospace fonts, box drawing chars where appropriate
   - Density: Compact spacing, but not cramped (use :sm/:md spacing)
   - Contrast: Ensure good readability (light text on dark backgrounds)
   - Consistency: All similar elements should look the same
   - Clarity: Class names should be semantic (btn-primary vs button-1)

   Box drawing characters for borders (optional, use sparingly):
   ┌ ┐ └ ┘ ─ │ ├ ┤ ┬ ┴ ┼

   Status icons to use:
   ● (running) ○ (pending) ✓ (success) ✗ (failed) ⏳ (waiting) ◐ (blocked)

   Risk indicators:
   🔴 (high) 🟡 (medium) 🟢 (low)"

  :helper-functions
  "You may need small helper functions for class name building:

   (defn build-class
     \"Build CSS class string from opts.\"
     [{:keys [class] :as opts} base-class & modifiers]
     (str/join \" \" (filter some? (concat [base-class] modifiers [class]))))

   Example usage:
   (build-class {:class \"custom\"} \"btn\" \"btn-primary\" \"btn-lg\")
   ;=> \"btn btn-primary btn-lg custom\""

  :testing-approach
  "You can verify components by:
   1. Creating a test view that renders all components
   2. Starting server: bb miniforge web
   3. Visiting http://localhost:8080/test-components
   4. Checking visual output

   Or write unit tests that check hiccup structure:
   (deftest button-test
     (is (= (button \"Click\" {:variant :primary})
            [:button.btn.btn-primary \"Click\"])))"}

 :spec/acceptance-criteria
 [{:criterion "CSS design system complete"
   :verification
   "- All color/spacing/typography tokens defined as CSS variables
    - Reset and base styles applied
    - Utility classes available (flex, gap, margin, padding, etc.)
    - File ≤200 lines"}

  {:criterion "Component library covers all needed elements"
   :verification
   "- All primitives implemented (button, badge, card, stat-card, progress-bar, status-dot, icon)
    - All layouts implemented (page, panel, grid, split)
    - All data display implemented (table, tree, timeline)
    - Each component is a pure function
    - Each component ≤30 lines"}

  {:criterion "Components are well-designed"
   :verification
   "- Consistent API patterns (content first, opts map second)
    - Clear docstrings
    - Semantic CSS class names
    - Variants/options work as specified"}

  {:criterion "Code quality"
   :verification
   "- Zero linting errors: clj-kondo --lint components/web-dashboard/src
    - Follows Rule 210 (stratification: ≤3 layers)
    - Follows Rule 720 (file size: ≤400 lines)
    - Copyright headers present"}

  {:criterion "Visual quality"
   :verification
   "- Terminal aesthetic achieved (monospace, dark theme, clean)
    - Good contrast and readability
    - Components look polished, not rushed
    - Spacing is consistent and pleasant"}]

 :success-criteria
 "This phase is successful if:
  1. A human reviewer looks at the CSS and thinks 'this is clean and well-organized'
  2. A human reviewer looks at the component library and thinks 'I can build any view with these'
  3. The visual output looks professional and aesthetic
  4. The code is maintainable and follows best practices

  This is a test of miniforge's ability to:
  - Translate design specs into clean code
  - Make aesthetic judgments (spacing, sizing, colors)
  - Write maintainable, well-documented code
  - Follow architectural constraints (stratification, PR sizing)"

 :next-phase
 "If this phase succeeds, Phase 2 will use these components to build the
  Dashboard Overview page (Tableau-inspired metrics view).

  If this phase reveals areas for improvement, we'll iterate and refine before
  proceeding to Phase 2."}
