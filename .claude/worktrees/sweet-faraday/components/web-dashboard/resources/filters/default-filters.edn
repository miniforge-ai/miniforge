;; Default filter specifications for web dashboard
;; These define the filterable fields available across all panes

[;; =============================================================================
 ;; Global Context Filters
 ;; =============================================================================

 {:filter/id :repository
  :filter/label "Repository"
  :filter/type :enum
  :filter/scope :global
  :filter/applicable-to #{:task-status :fleet}
  :filter/value {:kind :derived :derived/id :derived/repository}
  :filter/values :dynamic}

 {:filter/id :train-name
  :filter/label "Train"
  :filter/type :enum
  :filter/scope :global
  :filter/applicable-to #{:fleet :evidence}
  :filter/value {:kind :derived :derived/id :derived/train-name}
  :filter/values :dynamic}

 {:filter/id :entity-status
  :filter/label "Status"
  :filter/type :enum
  :filter/scope :global
  :filter/applicable-to #{:task-status :fleet :workflows}
  :filter/value {:kind :derived :derived/id :derived/entity-status}
  :filter/values :dynamic}

 {:filter/id :text-search
  :filter/label "Search"
  :filter/type :text
  :filter/scope :global
  :filter/applicable-to #{:task-status :fleet :evidence :workflows}
  :filter/value {:kind :multi-path
                 :paths [[:repo]
                         [:title]
                         [:name]
                         [:phase]
                         [:train/name]
                         [:train-name]]}}

 ;; =============================================================================
 ;; Pane-Local Analysis Filters: Task Status
 ;; =============================================================================

 {:filter/id :task-repository
  :filter/label "Task Repository"
  :filter/type :enum
  :filter/scope :local
  :filter/applicable-to #{:task-status}
  :filter/value {:kind :path :path [:repo]}
  :filter/values :dynamic}

 {:filter/id :task-title
  :filter/label "Task Title"
  :filter/type :text
  :filter/scope :local
  :filter/applicable-to #{:task-status}
  :filter/value {:kind :path :path [:title]}}

 ;; =============================================================================
 ;; Pane-Local Analysis Filters: Fleet
 ;; =============================================================================

 {:filter/id :fleet-status
  :filter/label "Train Status"
  :filter/type :enum
  :filter/scope :local
  :filter/applicable-to #{:fleet}
  :filter/value {:kind :path :path [:train/status]}
  :filter/values [:open :reviewing :merging :merged :failed]}

 {:filter/id :fleet-blocking-prs
  :filter/label "Has Blocking PRs"
  :filter/type :bool
  :filter/scope :local
  :filter/applicable-to #{:fleet}
  :filter/value {:kind :derived :derived/id :derived/has-blocking-prs}}

 {:filter/id :fleet-train-name
  :filter/label "Train Name"
  :filter/type :text
  :filter/scope :local
  :filter/applicable-to #{:fleet}
  :filter/value {:kind :path :path [:train/name]}}

 ;; =============================================================================
 ;; Pane-Local Analysis Filters: Workflows
 ;; =============================================================================

 {:filter/id :workflow-status
  :filter/label "Workflow Status"
  :filter/type :enum
  :filter/scope :local
  :filter/applicable-to #{:workflows}
  :filter/value {:kind :path :path [:status]}
  :filter/values [:running :completed]}

 {:filter/id :workflow-phase
  :filter/label "Workflow Phase"
  :filter/type :enum
  :filter/scope :local
  :filter/applicable-to #{:workflows}
  :filter/value {:kind :path :path [:phase]}
  :filter/values :dynamic}

 {:filter/id :workflow-name
  :filter/label "Workflow Name"
  :filter/type :text
  :filter/scope :local
  :filter/applicable-to #{:workflows}
  :filter/value {:kind :path :path [:name]}}

 ;; =============================================================================
 ;; Pane-Local Analysis Filters: Evidence
 ;; =============================================================================

 {:filter/id :has-evidence
  :filter/label "Evidence Available"
  :filter/type :bool
  :filter/scope :local
  :filter/applicable-to #{:evidence}
  :filter/value {:kind :derived :derived/id :derived/has-evidence}}

 {:filter/id :evidence-train-name
  :filter/label "Train Name"
  :filter/type :text
  :filter/scope :local
  :filter/applicable-to #{:evidence}
  :filter/value {:kind :path :path [:train-name]}}]
