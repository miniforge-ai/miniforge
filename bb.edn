{:min-bb-version "1.3.0"

 :deps {io.github.lispyclouds/bblgum {:git/sha "df647fb50f32e05b26e46e58d7249b4798e469e6"}
        ai.miniforge/bb-utils {:local/root "projects/bb-utils"}}

 :paths ["tasks"]

 :tasks
 {:requires ([babashka.fs :as fs]
             [babashka.process :as p]
             [ai.miniforge.bb-dev-tools.interface :as bb-dev-tools]
             [clojure.string :as str])

  :init (do
          (defn run! [& args]
            (let [{:keys [exit]} (apply p/sh args)]
              (when-not (zero? exit)
                (System/exit exit))))

          (defn run-stream! [& args]
            (let [{:keys [exit]} (deref (apply p/process {:out :inherit :err :inherit} args))]
              exit))

          (def os-key
            (let [n (str/lower-case (or (System/getProperty "os.name") ""))]
              (cond (str/includes? n "mac")     :macos
                    (str/includes? n "windows") :windows
                    :else                       :linux)))

          ;; fs/which is portable: invokes `which` on Unix, `where` on Windows.
          (defn installed? [cmd]
            (some? (fs/which cmd)))

          ;; Per-formula install routing. brew formulas like "borkdude/brew/clj-kondo"
          ;; map to a single command name (last path segment), which is what
          ;; both `installed?` and the Windows scoop bucket expect.
          ;; Scoop packages assume the user has run:
          ;;   scoop bucket add scoop-clojure https://github.com/littleli/scoop-clojure
          ;;   scoop bucket add extras
          ;; (see docs/platform-support.md). When we don't have an automated path
          ;; (Linux), we print install instructions instead of failing — this keeps
          ;; bb bootstrap recoverable on any platform.
          (def manual-install-hints
            {"clojure"          "https://clojure.org/guides/install_clojure"
             "clj-kondo"        "https://github.com/clj-kondo/clj-kondo/blob/master/doc/install.md"
             "markdownlint"     "npm install -g markdownlint-cli"
             "poly"             "https://polylith.gitbook.io/polylith/install"
             "bb"               "curl -sLO https://raw.githubusercontent.com/babashka/babashka/master/install && chmod +x install && ./install --static"
             "java"             "Install Temurin 21 via your distro package manager (apt/dnf/pacman)"})

          (defn- formula->cmd [formula]
            (last (str/split formula (re-pattern "/"))))

          (defn brew-install [formula]
            (let [cmd (formula->cmd formula)]
              (cond
                (installed? cmd)
                (println "  ✓" formula "already installed")

                (= os-key :macos)
                (do (println "  ⬇️ Installing" formula "via brew ...")
                    (p/shell "brew" "install" formula))

                (= os-key :windows)
                (do (println "  ⬇️ Installing" cmd "via scoop ...")
                    (p/shell {:continue true} "scoop" "install" cmd))

                :else
                (do (println "  ⚠️  No automated installer for" cmd "on" (name os-key))
                    (when-let [hint (get manual-install-hints cmd)]
                      (println "      Install manually:" hint))))))

          (defn brew-upgrade [formula]
            (let [cmd (formula->cmd formula)]
              (cond
                (= os-key :macos)
                (do (println "  ⬆️ Upgrading" formula "via brew ...")
                    (p/shell {:continue true} "brew" "upgrade" formula))

                (= os-key :windows)
                (do (println "  ⬆️ Upgrading" cmd "via scoop ...")
                    (p/shell {:continue true} "scoop" "update" cmd))

                :else
                (do (println "  ⚠️  No automated upgrader for" cmd "on" (name os-key))
                    (when-let [hint (get manual-install-hints cmd)]
                      (println "      Upgrade per:" hint)))))))

  ;; ──────────────────────────────────────────────────────────────────────────
  ;; Linting & Formatting
  ;; ──────────────────────────────────────────────────────────────────────────

  lint:clj
  {:doc  "Lint staged Clojure files with clj-kondo"
   :requires ([lint])
   :task (lint/clj-staged)}

  lint:clj:all
  {:doc  "Lint all Clojure files in the project"
   :requires ([lint])
   :task (lint/clj-all)}

  fmt:md
  {:doc  "Format staged Markdown files (lint --fix)"
   :requires ([fmt])
   :task (fmt/md-staged)}

  fmt:md:all
  {:doc  "Format all Markdown files in the project"
   :task (do
           (println "📝 Formatting all Markdown files...")
           (run! "markdownlint" "--fix" "."))}

  ;; ──────────────────────────────────────────────────────────────────────────
  ;; Testing
  ;; ──────────────────────────────────────────────────────────────────────────

  test
  {:doc  "Run changed brick tests in parallel (since main)"
   :task (let [exit (run-stream! "bb" "scripts/test-changed-bricks.bb")]
           (when-not (zero? exit)
             (System/exit exit)))}

  test:poly
  {:doc  "Run unit (brick) tests via Polylith (full, serial)"
   :task (do
           (println "🧪 Running tests via poly test...")
           (println "Command: clojure -M:poly test")
           (let [exit (run-stream! "clojure" "-M:poly" "test")]
             (when-not (zero? exit)
               (println "❌ Tests failed with exit code:" exit)
               (System/exit exit))))}

  test:integration
  {:doc  "Run project-level integration tests"
   :requires ([test-runner])
   :task (test-runner/integration)}

  test:all
  {:doc  "Run full suite (unit bricks + project integration tests)"
   :task (do
           (run 'test)
           (run 'test:integration))}

  ccov
  {:doc  "Run the repo coverage toolset from bb-tools.edn"
   :task (let [exit (bb-dev-tools/run-toolset {:repo-root "."
                                               :toolset-id :toolset/coverage})]
           (when-not (zero? exit)
             (System/exit exit)))}

  test:conformance
  {:doc  "Run N1 conformance test suite"
   :requires ([test-runner])
   :task (test-runner/conformance)}

  test:graalvm
  {:doc  "Test GraalVM/Babashka compatibility"
   :requires ([test-runner])
   :task (test-runner/graalvm)}

  ;; ──────────────────────────────────────────────────────────────────────────
  ;; Pre-commit
  ;; ──────────────────────────────────────────────────────────────────────────

  pre-commit
  {:doc     "Run all pre-commit checks (lint, format, test, graalvm)"
   :depends [lint:clj fmt:md test test:graalvm]
   :task    (println "\n✅ ALL PRE-COMMIT CHECKS PASSED\n")}

