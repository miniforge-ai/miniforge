  ;; Standards — policy pack compilation & self-review
  ;; ──────────────────────────────────────────────────────────────────────────

  standards:pack
  {:doc  "Compile .standards/ MDC files into a policy pack EDN resource"
   :requires ([standards])
   :task (standards/pack)}

  review
  {:doc  "Self-review: run compliance scanner on this repo (--fix to auto-fix)"
   :requires ([standards])
   :task (standards/review *command-line-args*)}

  work:queue
  {:doc  "Render the prioritized work-spec queue (stdout + work/QUEUE.md)"
   :requires ([work])
   :task (work/queue)}

  work:theme
  {:doc  "Render a single theme's specs (usage: bb work:theme <theme-id>)"
   :requires ([work])
   :task (work/theme *command-line-args*)}

  ;; ──────────────────────────────────────────────────────────────────────────
  ;; Building
  ;; ──────────────────────────────────────────────────────────────────────────

  clean
  {:doc  "Clean all build artifacts"
   :task (do
           (println "🧹 Cleaning build artifacts...")
           (run! "clojure" "-T:build" "clean"))}

  build:script
  {:doc  "Build BB dev script for a project (uses absolute paths)"
   :task (let [[project] *command-line-args*]
           (if project
             (do
               (println "🔨 Building BB script for project:" project)
               (run! "clojure" "-T:build" "bb-script" (str ":project " project)))
             (println "Usage: bb build:script <project>")))}

  build:cli
  {:doc  "Build miniforge CLI as distributable uberjar"
   :requires ([build])
   :task (build/cli)}

  build:kernel
  {:doc  "Build MiniForge Core CLI as distributable uberjar"
   :requires ([build])
   :task (build/kernel)}

  build:jar
  {:doc  "Build JVM uberjar for a project"
   :task (let [[project] *command-line-args*]
           (if project
             (do
               (println "🔨 Building uberjar for project:" project)
               (run! "clojure" "-T:build" "uberjar" (str ":project " project)))
             (println "Usage: bb build:jar <project>")))}

  build:all
  {:doc  "Build all changed projects"
   :task (do
           (println "🔨 Building all changed projects...")
           (run! "clojure" "-T:build" "build-all"))}

  build:tui
  {:doc  "Build miniforge-tui as JVM uberjar + jlink runtime"
   :requires ([build])
   :task (build/tui)}

  install:tui
  {:doc  "Build and install miniforge-tui to ~/.local/bin"
   :requires ([install])
   :task (install/tui)}

  compile
  {:doc  "Compile all code (syntax check)"
   :requires ([build])
   :task (build/compile-all)}

  ;; ──────────────────────────────────────────────────────────────────────────
  ;; Local Installation (for testing)
  ;; ──────────────────────────────────────────────────────────────────────────

  install:local
  {:doc  "Build and install CLI to ~/.local/bin/mf (cleans old build first)"
   :requires ([install])
   :task (install/local-cli)}

  uninstall:local
  {:doc  "Remove local installation from ~/.local/bin/mf"
   :task (let [target (str (System/getProperty "user.home") "/.local/bin/mf")]
           (if (fs/exists? target)
             (do
               (println "🗑️  Removing" target)
               (fs/delete target)
               (println "✅ Uninstalled successfully"))
             (println "✓ Not installed at" target)))}

  test:local
  {:doc     "Build CLI, install locally, and test"
   :depends [build:cli install:local]
   :task    (do
              (println "\n🧪 Testing local installation...\n")
              (p/shell "mf" "version")
              (p/shell "mf" "help")
              (println "\n✅ Local installation test complete\n"))}

  ;; ──────────────────────────────────────────────────────────────────────────
  ;; Release & Stability
  ;; ──────────────────────────────────────────────────────────────────────────

  release
  {:doc  "Tag a release + stable tag, push to trigger CI build + Homebrew update"
   :requires ([release])
   :task (release/cut!)}

  stable
  {:doc  "Run full test suite and tag as stable if green (for poly change detection)"
   :requires ([release])
   :task (release/stable!)}

  ;; ──────────────────────────────────────────────────────────────────────────
  ;; Installers (via Homebrew)
  ;; ──────────────────────────────────────────────────────────────────────────

  install:java
  {:doc  "Install Java (Temurin 21)"
   :task (cond
           (installed? "java")
           (println "  ✓ java already installed")

           (= os-key :macos)
           (p/shell "brew" "install" "--cask" "temurin@21")

           (= os-key :windows)
           (do (println "  ⬇️ Installing Temurin 21 via scoop ...")
               (p/shell {:continue true} "scoop" "install" "temurin21-jdk"))

           :else
           (do (println "  ⚠️  No automated Java installer on" (name os-key))
               (println "      Install Temurin 21 via your distro package manager (apt/dnf/pacman)")))}

  install:clojure
  {:doc  "Install Clojure CLI"
   :task (brew-install "clojure/tools/clojure")}

  install:clj-kondo
  {:doc  "Install clj-kondo linter"
   :task (brew-install "borkdude/brew/clj-kondo")}

  install:coverage
  {:doc  "Install or prefetch the repo coverage toolset from bb-tools.edn"
   :task (let [exit (bb-dev-tools/install-toolset {:repo-root "."
                                                   :toolset-id :toolset/coverage})]
           (when-not (zero? exit)
             (System/exit exit)))}

  install:markdownlint
  {:doc  "Install markdownlint-cli"
   :task (cond
           (installed? "markdownlint")
           (println "  ✓ markdownlint-cli already installed")

           (= os-key :macos)
           (p/shell "brew" "install" "markdownlint-cli")

           ;; markdownlint-cli is an npm package — same install on Win/Linux.
           :else
           (if (installed? "npm")
             (do (println "  ⬇️ Installing markdownlint-cli via npm ...")
                 (p/shell {:continue true} "npm" "install" "-g" "markdownlint-cli"))
             (do (println "  ⚠️  npm not found.")
                 (println "      Install Node.js + npm, then: npm install -g markdownlint-cli"))))}

  install:poly
  {:doc  "Install Polylith CLI"
   :task (brew-install "polyfy/polylith/poly")}

  install:deps
  {:doc     "Install all required dependencies"
   :depends [install:java install:clojure install:clj-kondo install:markdownlint install:poly]
   :task    (println "\n✅ All dependencies installed")}

  check:platform
  {:doc  "Report OS, shell, and required-tool status"
   :task (let [props      (System/getProperties)
               os-name    (.get props "os.name")
               os-arch    (.get props "os.arch")
               shell      (or (System/getenv "SHELL")
                              (System/getenv "ComSpec")
                              "(unknown)")
               java-ver   (.get props "java.version")
               bb-ver     (System/getProperty "babashka.version")
               check      (fn [cmd]
                            (if (installed? cmd)
                              (str "  ✓ " cmd)
                              (str "  ✗ " cmd " (not on PATH)")))]
           (println "Miniforge platform check")
           (println "────────────────────────")
           (println "  OS       :" os-name "(" (name os-key) ")")
           (println "  Arch     :" os-arch)
           (println "  Shell    :" shell)
           (println "  Java     :" java-ver)
           (println "  Babashka :" bb-ver)
           (println)
           (println "Required tools:")
           (doseq [cmd ["java" "clojure" "clj-kondo" "poly" "git" "markdownlint"]]
             (println (check cmd)))
           (when (= os-key :windows)
             (println)
             (println "Windows notes:")
             (println "  • bb bootstrap routes brew installs to scoop on Windows.")
             (println "  • Ensure these scoop buckets are added:")
             (println "      scoop bucket add scoop-clojure https://github.com/littleli/scoop-clojure")
             (println "      scoop bucket add extras")
             (println "  • run-demo.sh requires Git Bash or WSL2.")
             (println "  • See docs/platform-support.md for the full status matrix.")))}

