;; Example: Add tests to phase files generated by miniforge
;; ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
;;
;; This workflow spec demonstrates using the test-only workflow to generate
;; tests for existing code (in this case, the phase files that miniforge
;; generated for itself in the meta-meta loop).
;;
;; Usage:
;;   mf run examples/workflows/add-tests-to-phase-files.edn

{:workflow/spec-version "1.0.0"

 :spec/title "Add tests for verify, review, and release phases"
 :spec/description
 "Generate comprehensive tests for the phase interceptor files that were
  generated by miniforge during the meta-meta loop. These files need test
  coverage to ensure quality and prevent regressions."

 :spec/intent
 "Create unit tests and integration tests for the phase interceptor implementations,
  focusing on:
  - Phase lifecycle (enter, leave, error handlers)
  - Agent invocation and result handling
  - Metrics tracking and aggregation
  - Error recovery and retry logic
  - Context propagation through phases"

 :spec/constraints
 ["Use clojure.test framework"
  "Follow existing test patterns in the codebase"
  "Aim for 80%+ code coverage"
  "Test both happy path and error conditions"
  "Mock LLM calls to avoid external dependencies"
  "Test files should mirror source structure: test/ai/miniforge/phase/*_test.clj"]

 ;; Input: Code artifact from the evidence bundle
 ;; NOTE: In a real workflow, you would:
 ;;   1. Use the evidence bundle from a previous workflow run (output artifact)
 ;;   2. Read files from disk using a helper script
 ;;   3. Have miniforge generate this structure automatically
 ;;
 ;; For now, this shows the expected structure. The actual file contents
 ;; would need to be included in the :content field of each file.
 :spec/code-artifact
 {:code/id #uuid "a1b2c3d4-e5f6-7890-1234-567890abcdef"
  :code/language "clojure"
  :code/files
  [{:path "components/phase/src/ai/miniforge/phase/verify.clj"
    :content "...file content would go here..."
    :action :test-existing}
   {:path "components/phase/src/ai/miniforge/phase/review.clj"
    :content "...file content would go here..."
    :action :test-existing}
   {:path "components/phase/src/ai/miniforge/phase/release.clj"
    :content "...file content would go here..."
    :action :test-existing}]}

 :spec/acceptance-criteria
 ["Tests cover all public functions in each phase file"
  "Tests verify proper agent invocation and result handling"
  "Tests verify metrics are correctly tracked and merged"
  "Tests verify error handling and retry logic"
  "Tests verify phase state transitions (pending -> running -> completed)"
  "Tests use mocks for LLM backend to avoid external calls"
  "All tests pass when run"
  "Test coverage meets 80% threshold"]}
