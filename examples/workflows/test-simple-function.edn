;; Example: Generate tests for a simple utility function
;; ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
;;
;; This is a minimal, working example of the test-only workflow.
;; It generates tests for a simple utility function.
;;
;; Usage:
;;   mf run examples/workflows/test-simple-function.edn

{:workflow/spec-version "1.0.0"
 :workflow/type :test-only
 :workflow/version "2.0.0"

 :task/title "Generate tests for string utility functions"
 :task/description
 "Create comprehensive tests for a simple string utility module that provides
  common string manipulation functions."

 :task/intent
 "Generate unit tests covering all edge cases for string utility functions,
  including empty strings, nil values, unicode handling, and boundary conditions."

 :task/constraints
 ["Use clojure.test framework"
  "Test all edge cases (nil, empty string, whitespace only)"
  "Include property-based tests for string reversal"
  "Aim for 100% code coverage"
  "Tests should be clear and self-documenting"]

 ;; Code artifact with actual content inline
 :task/code-artifact
 {:code/id #uuid "12345678-1234-1234-1234-123456789abc"
  :code/language "clojure"
  :code/summary "String utility functions for common text manipulations"
  :code/files
  [{:path "src/utils/string.clj"
    :action :test-existing
    :content "(ns utils.string
  \"Common string utility functions.\"
  (:require [clojure.string :as str]))

(defn reverse-string
  \"Reverses a string. Returns nil if input is nil.\"
  [s]
  (when s
    (str/reverse s)))

(defn truncate
  \"Truncates a string to max-length, adding ellipsis if truncated.
   Returns original string if shorter than max-length.\"
  [s max-length]
  (when s
    (if (<= (count s) max-length)
      s
      (str (subs s 0 (- max-length 3)) \"...\"))))

(defn capitalize-words
  \"Capitalizes the first letter of each word in a string.\"
  [s]
  (when s
    (->> (str/split s #\"\\\\s+\")
         (map str/capitalize)
         (str/join \" \"))))"}]}

 :task/acceptance-criteria
 ["Tests verify reverse-string handles nil, empty, single char, and multi-char strings"
  "Tests verify truncate handles strings shorter, equal, and longer than max-length"
  "Tests verify capitalize-words handles single words, multiple words, and mixed case"
  "Tests verify all functions handle nil input gracefully"
  "Tests verify Unicode/emoji handling where applicable"
  "All tests pass when run"
  "Property-based test verifies reverse-string(reverse-string(x)) == x"]}
