;; Implement Pre-Commit Discipline Policy Gate
;; ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
;;
;; This workflow implements a policy gate to enforce rule 715-pre-commit-discipline.
;; The gate will detect and flag commits that bypassed pre-commit hooks without
;; proper documentation and justification.
;;
;; Usage:
;;   mf run examples/workflows/implement-pre-commit-discipline-gate.edn

{:workflow/spec-version "1.0.0"
 :workflow/type :standard-sdlc
 :workflow/version "2.0.0"

 :title "Implement Pre-Commit Discipline Policy Gate"
 :description
 "Create a policy gate that enforces .cursor/rules/700-workflows/715-pre-commit-discipline.mdc.

  The gate should:
  1. Check git history for commits made with --no-verify
  2. Validate that bypassed commits have proper [BYPASS-HOOKS: reason] documentation
  3. Verify manual validation steps were documented
  4. Flag violations with appropriate severity
  5. Integrate into the workflow execution pipeline"

 :intent
 {:type "feature"
  :description "Implement automated enforcement of pre-commit discipline to prevent
  bypass shortcuts without investigation. This addresses the pattern where agents
  (or developers) bypass hooks due to impatience rather than fixing root causes.

  Context: During recent GraalVM compatibility work (PR #96), the agent bypassed
  pre-commit hooks using --no-verify because tests were taking ~2 minutes to run.
  This violated rule 715 which explicitly states 'It's taking too long' is NOT
  a valid reason for bypass.

  The gate will make this pattern immediately visible during workflow execution,
  giving the meta-agent a chance to intervene before code reaches CI."}

 :constraints
 ["Follow N4 spec §2.0 for policy gate structure"
  "Integrate with existing gate system in components/gate"
  "Use git log analysis to detect --no-verify commits"
  "Validate [BYPASS-HOOKS: reason] format per rule 715"
  "Support severity levels: error, warning, info"
  "Add comprehensive unit tests for all bypass scenarios"
  "Document gate behavior in gate README"
  "Follow Polylith interface patterns"
  "Maintain backward compatibility with existing gates"]

 :acceptance-criteria
 ["Gate implementation in components/gate/src/.../pre_commit_discipline.clj"
  "Detects commits made with --no-verify in current branch"
  "Validates [BYPASS-HOOKS: reason] is present in bypassed commits"
  "Validates manual validation steps are documented (tests, lint, format)"
  "Returns :error severity for unjustified bypasses"
  "Returns :warning severity for justified but poorly documented bypasses"
  "Returns :info for properly documented emergency bypasses"
  "Unit tests cover all bypass scenarios (valid, invalid, emergency)"
  "Integration test demonstrates gate blocking workflow on violation"
  "Gate is registered in gate registry for automatic execution"
  "Documentation added to components/gate/README.md"
  "Example violation scenarios in test fixtures"]

 :context
 {:supporting-docs
  [".cursor/rules/700-workflows/715-pre-commit-discipline.mdc"
   "specs/normative/N4-Policy-Packs-Gates.md"
   "components/gate/README.md"
   "components/gate/src/ai/miniforge/gate/interface.clj"]

  :real-world-example
  "PR #96: GraalVM compatibility fix used --no-verify because pre-commit took
  ~2min to run. The agent reasoning was:
  - 'Tests passed manually' (ran bb test:graalvm)
  - 'CI will catch it anyway'
  - 'It's taking too long'

  All three are explicitly called out as anti-patterns in rule 715:
  - Line 83: 'It's taking too long' - Speed is not a valid reason
  - Line 84: 'CI will catch it anyway' - That's wasteful; fix it now
  - Line 85: 'The hook suggests I can bypass' - BUT YOU REALLY SHOULDN'T!

  This gate would have caught this during workflow execution and flagged it
  before the commit reached CI, giving the meta-agent a chance to course-correct."}

 :meta-loop-monitoring
 {:test-with-violation
  "Create a test commit with --no-verify and verify the gate catches it"

  :test-with-proper-bypass
  "Create a test commit with --no-verify but proper [BYPASS-HOOKS: reason]
   documentation and verify the gate allows it with warning"

  :test-meta-agent-intervention
  "Verify that when the gate fires during workflow execution, the meta-agent
   can see the violation and take corrective action (pause workflow, require fix)"}

 :evidence-requirements
 ["Gate implementation passes all unit tests"
  "Integration test demonstrates violation detection"
  "Example in test fixtures shows proper [BYPASS-HOOKS:] format"
  "Documentation clearly explains when gate triggers"
  "Meta-agent can query gate status during workflow execution"]}
