 :implementation
 {:phase-1-model-registry
  {:files-to-create
   ["components/llm/src/ai/miniforge/llm/model_registry.clj (~250 lines)"
    "- Model capability definitions"
    "- Query by capability (reasoning, speed, cost)"
    "- Query by use-case"
    "- Get recommended model for task type"]

   :model-registry-structure
   "(def model-registry
      {:opus-4.6 {:capabilities {...} :best-for [...] :use-cases [...]}
       :sonnet-4.5 {...}
       :haiku-4.5 {...}
       :gpt-5.3-codex {...}})

    (defn get-models-by-capability [capability min-level]
      ;; e.g., (get-models-by-capability :reasoning :excellent)
      ;; => [:opus-4.6 :gpt-5.3-codex])

    (defn recommend-model-for-task [task-characteristics]
      ;; Returns {:model :sonnet-4.5 :rationale \"...\"})"}

  :phase-2-task-classifier
  {:files-to-create
   ["components/agent/src/ai/miniforge/agent/task_classifier.clj (~200 lines)"
    "- Classify task as :thinking-heavy, :execution-focused, :simple-validation"
    "- Analyze task description, spec, phase, agent type"
    "- Return classification with confidence"]

   :classification-logic
   "(defn classify-task [{:keys [phase agent-type description spec]}]
      (cond
        (#{:plan :research :architecture} phase)
        {:type :thinking-heavy :confidence 0.95}

        (#{:validate :format :syntax-check} phase)
        {:type :simple-validation :confidence 0.9}

        :else
        {:type :execution-focused :confidence 0.8}))"}

  :phase-3-model-selector
  {:files-to-create
   ["components/llm/src/ai/miniforge/llm/model_selector.clj (~200 lines)"
    "- Select optimal model given task classification"
    "- Consider cost constraints"
    "- Fallback to alternatives if primary unavailable"
    "- Explain selection reasoning"]

   :selection-logic
   "(defn select-model [task-classification & {:keys [cost-limit]}]
      (let [task-type (:type task-classification)
            recommendations (get-in task-classification-map
                                   [task-type :recommended-models])
            primary (:primary recommendations)]
        (if (model-available? primary)
          {:model primary
           :rationale (:rationale recommendations)
           :confidence (:confidence task-classification)}
          {:model (:fallback recommendations)
           :rationale \"Primary unavailable, using fallback\"})))"}

  :phase-4-integration
  {:files-to-modify
   ["components/agent/src/ai/miniforge/agent/core.clj"
    "- Before creating agent, classify task"
    "- Select appropriate model"
    "- Pass model to LLM client"
    "- Log model selection reasoning"]

   :workflow-integration
   ["components/workflow/src/ai/miniforge/workflow/phase.clj"
    "- Each phase can specify model requirements"
    "- Override automatic selection if needed"
    "- E.g., {:phase :plan :require-model :opus-4.6}"]}}

