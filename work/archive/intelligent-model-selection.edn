   miniforge config set model-selection.strategy fixed
   miniforge config set llm.model claude-sonnet-4-5

   # Enable cost optimization:
   miniforge config set model-selection.strategy cost-optimized
   miniforge config set model-selection.cost-limit 0.05

   # Force specific model for workflow:
   :spec/model-override :opus-4.6"}

