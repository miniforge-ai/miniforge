;; Frictionless Configuration System

{:spec/title "Frictionless Configuration: Backends, Workflows, and Settings"
 :version "1.0.0"
 :type :enhancement
 :priority :critical

 :spec/description
 "Make miniforge configuration simple, discoverable, and frictionless. Users
  should be able to set backends (Codex, Claude, etc.), configure workflows,
  and manage settings without reading docs or editing config files.

  Current problem: Configuration is a rite of passage - users must know:
  - What backends exist (only :claude and :echo are defined!)
  - How to set them (env vars? config file in resources?)
  - What settings are available
  - How workflows are configured

  This is unacceptable UX. Configuration must be paramount, simple, frictionless."

 :spec/intent
 {:type :user-experience-overhaul
  :scope ["LLM backend management"
          "Configuration discovery and CLI"
          "Multiple LLM provider support"
          "User-friendly settings management"
          "Clear documentation and help"]

  :context
   {:triggering-issue
    ["User wants to set backend to Codex - it's unclear how"
     "Codex backend doesn't even exist in the codebase"
     "Only :claude and :echo backends defined"
     "Config commands broken (dispatch error)"
     "Config file in resources/ (not user-accessible)"
     "Must use MINIFORGE_LLM_BACKEND env var (not discoverable)"
     "No way to list available backends"
     "No way to see current configuration easily"]

    :user-quote
    "It's unclear how to do that. From the user POV creating new workflows,
     setting backends, configuring miniforge needs to be paramount, simple
     and frictionless. It can't be the typical devops tools that make config
     a rite of passage."

    :current-ux-flow
    ["User: 'How do I use Codex?'"
     "System: *silence* (no Codex backend exists)"
     "User: 'miniforge config --help'"
     "System: *error* (babashka/cli dispatch broken)"
     "User: 'Where is config?'"
     "System: *silence* (buried in bases/cli/resources/config.edn)"
     "User: *frustrated, gives up*"]

    :desired-ux-flow
    ["User: 'miniforge config backends'"
     "System: Shows available backends with descriptions"
     "User: 'miniforge config set llm.backend codex'"
     "System: ✅ Backend set to codex, saves to ~/.miniforge/config.edn"
     "User: 'miniforge config get llm.backend'"
     "System: codex"
     "User: *happy, productive*"]}}

 :requirements
 [{:id "R1"
   :requirement "Support multiple LLM backends"
   :providers
   ["Claude (Anthropic CLI)"
    "Codex (OpenAI API)"
    "OpenAI GPT-4"
    "Cursor (Cursor CLI)"
    "Ollama (local models)"
    "Azure OpenAI"
    "Echo (testing)"]
   :must-have [:claude :codex :openai :cursor :echo]
   :nice-to-have [:ollama :azure-openai]}

  {:id "R2"
   :requirement "Simple CLI for configuration"
   :commands
   ["miniforge config list                    # Show all config"
    "miniforge config get <key>               # Get specific value"
    "miniforge config set <key> <value>       # Set value"
    "miniforge config backends                # List available backends"
    "miniforge config backend <name>          # Set backend (shorthand)"
    "miniforge config init                    # Create user config file"
    "miniforge config edit                    # Open config in $EDITOR"
    "miniforge config reset                   # Reset to defaults"]
   :no-errors true
   :helpful-output true}

  {:id "R3"
   :requirement "User config file in standard location"
   :location "~/.miniforge/config.edn"
   :precedence ["~/.miniforge/config.edn (user config)"
                "Environment variables (MINIFORGE_*)"
                "bases/cli/resources/config.edn (defaults)"]
   :auto-create "Create user config on first run or 'config init'"}

  {:id "R4"
   :requirement "Discoverable configuration"
   :help-commands
   ["miniforge config --help                  # Show all config commands"
    "miniforge config backends --help         # Show backend options"
    "miniforge config get --help <key>        # Show what <key> controls"]
   :inline-help "Show available options when setting values"}

  {:id "R5"
   :requirement "Clear backend information"
   :backend-info
   "Each backend should show:
    - Name and provider
    - Description
    - Requirements (CLI tool, API key, etc.)
    - Installation instructions
    - Current status (available, missing, needs key)"}

  {:id "R6"
   :requirement "Validation and helpful errors"
   :examples
   ["Setting invalid backend → show available backends"
    "Missing API key → show how to set it"
    "Invalid config value → show valid options"
    "Broken config file → show fix suggestions"]}]

 :backend-specifications
 {:claude
  {:provider "Anthropic"
   :command "claude"
   :description "Claude via Anthropic CLI (claude command)"
   :installation "npm install -g @anthropic-ai/claude-cli"
   :api-key-var "ANTHROPIC_API_KEY"
   :streaming true
   :models ["claude-sonnet-4-20250514" "claude-opus-4-20250514" "claude-haiku-4-20250514"]
   :status-check "(process/shell \"which\" \"claude\")"}

  :codex
  {:provider "OpenAI"
   :command "api"
   :description "OpenAI Codex via OpenAI API"
   :installation "No CLI needed - uses API key"
   :api-key-var "OPENAI_API_KEY"
   :streaming true
   :models ["gpt-4-turbo" "gpt-4" "gpt-3.5-turbo"]
   :implementation "Use OpenAI HTTP API directly"
   :status-check "(System/getenv \"OPENAI_API_KEY\")"}

  :openai
  {:provider "OpenAI"
   :command "api"
   :description "OpenAI GPT-4 via OpenAI API"
   :installation "No CLI needed - uses API key"
   :api-key-var "OPENAI_API_KEY"
   :streaming true
   :models ["gpt-4-turbo" "gpt-4" "gpt-3.5-turbo"]
   :implementation "Same as :codex, different default model"
   :status-check "(System/getenv \"OPENAI_API_KEY\")"}

  :cursor
  {:provider "Cursor"
   :command "cursor-cli"
   :description "Cursor AI via Cursor CLI"
   :installation "Install Cursor from https://cursor.sh"
   :api-key-var nil
   :streaming false
   :models ["cursor-default"]
   :status-check "(process/shell \"which\" \"cursor-cli\")"}

  :ollama
  {:provider "Ollama"
   :command "ollama"
   :description "Local models via Ollama"
   :installation "brew install ollama"
   :api-key-var nil
   :streaming true
   :models ["codellama" "llama2" "mistral"]
   :status-check "(process/shell \"which\" \"ollama\")"}

  :echo
  {:provider "Test"
   :command "echo"
   :description "Echo backend for testing (no actual LLM)"
   :installation "Built-in"
   :api-key-var nil
   :streaming false
   :models ["echo"]
   :status-check "true"}}

