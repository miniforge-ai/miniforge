  {:files-to-modify
   ["bases/cli/src/ai/miniforge/cli/main.clj - Fix config command dispatch"]
   :issue "babashka/cli dispatch error with :input-exhausted"
   :fix "Add proper subcommand handling for config commands"
   :pr-size "~50 lines"}

  :phase-2-user-config-file
  {:files-to-create
   ["components/config/src/ai/miniforge/config/user.clj (~150 lines)"
    "- load-user-config from ~/.miniforge/config.edn"
    "- merge-configs (user > env > defaults)"
    "- save-user-config"
    "- init-user-config (create with defaults)"
    "- edit-user-config (open in $EDITOR)"]
   :pr-size "~200 lines"}

  :phase-3-backend-implementations
  {:files-to-modify
   ["components/llm/src/ai/miniforge/llm/protocols/impl/llm_client.clj"]
   :add-backends [:codex :openai :ollama]
   :implementation
   {:codex "HTTP API client using clj-http or babashka.http-client"
    :openai "Same as Codex, different default model"
    :ollama "HTTP API to localhost:11434"}
   :pr-size "~400 lines"}

  :phase-4-backend-discovery
  {:files-to-create
   ["bases/cli/src/ai/miniforge/cli/backends.clj (~200 lines)"
    "- list-backends (show all with status)"
    "- check-backend-status (available? needs-key? installed?)"
    "- get-backend-info (description, requirements, etc.)"
    "- set-backend (save to user config)"]
   :pr-size "~250 lines"}

  :phase-5-improved-config-cli
  {:files-to-modify
   ["bases/cli/src/ai/miniforge/cli/config.clj (~200 lines added)"
    "- list-cmd (show all config)"
    "- get-cmd (get specific key)"
    "- set-cmd (set key=value)"
    "- backends-cmd (list backends)"
    "- backend-cmd (set backend shorthand)"
    "- init-cmd (create user config)"
    "- edit-cmd (open in editor)"
    "- reset-cmd (reset to defaults)"
    "- validate-cmd (check config)"]
   :pr-size "~300 lines"}}

