{:title "Web Dashboard v2 - Complete & Polished"
 :version "2.0.0"
 :description
 "Build a production-ready web dashboard that combines:
  - 5 N5 views (workflow list/detail, evidence, artifacts, DAG kanban)
  - 3 N9 PR views (PR fleet, PR detail, train view)
  - Old dashboard features (AI chat, risk analysis, batch operations)
  - Tableau-inspired dense, informative visualizations
  - Server-side rendering + htmx (no build step for Homebrew deployment)"

 :intent
 {:type :feature-complete
  :scope ["Polished, production-ready web dashboard"
          "Dense information display (Tableau-inspired)"
          "PR fleet management with AI analysis"
          "Workflow monitoring with real-time updates"
          "Train dependency visualization"
          "Batch operations and automation controls"]

  :context
  {:current-state
   ["Basic 5 N5 views implemented (server-side + htmx)"
    "WebSocket event stream working"
    "Missing: PR features, AI chat, risk analysis, metrics dashboard"
    "Old dashboard exists at bases/cli/src/ai/miniforge/cli/web/* (reference)"]

   :design-inspiration
   ["Tableau dashboards (dense, visual, metrics-focused)"
    "Old miniforge dashboard (PR fleet, AI chat, batch ops)"
    "N5/N9 specs (TUI views, PR management)"
    "Control plane aesthetic (terminal feel, monospace, dark theme)"]

   :references
   ["N5 §3.2.1-3.2.5 (5 TUI views)"
    "N9 §3.2.8-3.2.10 (3 PR views)"
    "bases/cli/src/ai/miniforge/cli/web/* (old dashboard)"
    "Tableau public dashboards for visual patterns"
    "Rule 210-clojure.mdc (stratification)"
    "Rule 720-pr-layering (PR sizing)"]}}

 :constraints
 ["Server-side rendering only (no ClojureScript, no build step)"
  "Hiccup 2.0.0-RC3 for HTML generation"
  "htmx 2.0.0 for dynamic updates"
  "Cheshire for JSON (Babashka-compatible)"
  "http-kit for server + WebSocket"
  "All files ≤400 lines (Rule 720)"
  "All files ≤3 layers (Rule 210)"
  "Zero linting errors/warnings"
  "Works in Babashka (bb miniforge web)"]

 :architecture
 {:layout
  "┌─────────────────────────────────────────────────────────────┐
   │ MINIFORGE              🔴 2 HIGH  🟡 5 MED  🟢 12 LOW        │ Global header
   │                        ⏳ 3 Run   ✓ 45 Done  ✗ 2 Fail       │ Metrics bar
   ├────┬────────────────────────────────────────────────┬───────┤
   │Nav │ Main Content Area                              │Actions│
   │────│                                                 │───────│
   │Dash│ ┌──────────────────────────────────────────┐  │Batch  │
   │Work│ │  PRIMARY VIEW                            │  │Approve│
   │PRs │ │  (table, chart, timeline, etc.)          │  │       │
   │Trn │ │                                           │  │Filter │
   │Evid│ │  Dense, informative, visual              │  │Search │
   │Task│ └──────────────────────────────────────────┘  │       │
   └────┴────────────────────────────────────────────────┴───────┘"

  :views
