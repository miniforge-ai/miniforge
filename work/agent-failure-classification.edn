 {:unit-tests
  ["Test error pattern matching for each classification type"
   "Test message formatting with various error types"
   "Test URL generation with error context"
   "Test retry recommendation logic"
   "Test completed work extraction"]

  :integration-tests
  ["Simulate agent backend error (mock classifyHandoffIfNeeded failure)"
   "Simulate task code error (inject syntax error)"
   "Simulate external error (mock GitHub API failure)"
   "Verify error messages display correctly in CLI"
   "Verify reporting URLs are well-formed"]

  :manual-tests
  ["Review error messages for clarity and helpfulness"
   "Verify reporting URLs pre-fill issue templates correctly"
   "Test with real agent backend errors when they occur"
   "Verify completed work is shown accurately"]}

 :acceptance-criteria
 [{:criterion "All error types correctly classified"
   :verification "Unit tests pass for all pattern matching"}

  {:criterion "User-friendly error messages for each type"
   :verification "Manual review confirms messages are clear and actionable"}

  {:criterion "Reporting URLs work and pre-fill context"
   :verification "Click links in error messages, verify issue templates"}

  {:criterion "Completed work shown when present"
   :verification "Test with task that completes work then errors"}

