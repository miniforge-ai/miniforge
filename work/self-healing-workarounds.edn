;; Self-Healing Workaround System

{:title "Self-Healing Workaround Detection and Backend Fallback"
 :version "1.0.0"
 :type :enhancement
 :priority :critical

 :description
 "Implement self-healing behavior when vendor bugs block miniforge operation.
  When errors occur, automatically search for known workarounds, apply them,
  and track reliability metrics to switch backends when one becomes unreliable.

  Core principle: **Miniforge cannot be broken if a workaround exists.**"

 :motivation
 {:trigger "classifyHandoffIfNeeded bug in Claude Code v2.1.29-2.1.37"
  :impact "4 agents failed with false failures (work completed but marked failed)"
  :user-quote "This is going to happen a lot I am guessing and we can't be broken
               if a workaround exists"
  :current-problem
  ["Vendor bugs block miniforge operation"
   "Known workarounds exist but require manual intervention"
   "Users must discover issues, find workarounds, apply fixes"
   "No automatic recovery or resilience"
   "Single backend failure = total failure"]}

 :architecture
 {:layer-1-workaround-detection
  {:responsibility "Detect vendor bugs and find workarounds"
   :triggers ["Agent backend errors (:agent-backend classification)"
              "Repeated failures with same error pattern"
              "Task marked failed but work completed"]
   :actions
   ["Search vendor issue tracker (GitHub API)"
    "Parse issue body for workaround instructions"
    "Extract configuration changes or commands"
    "Present workaround to user or apply automatically"]}

  :layer-2-workaround-registry
  {:responsibility "Store and reuse known workarounds"
   :location "~/.miniforge/known_workarounds.edn"
   :structure
   "{:workarounds
     {:claude-code/classifyHandoffIfNeeded
      {:error-pattern #\"classifyHandoffIfNeeded is not defined\"
       :vendor :claude-code
       :issue-url \"https://github.com/anthropics/claude-code/issues/22573\"
       :severity :p1
       :workaround
       {:type :settings-modification
        :description \"Disable SubagentStop hooks\"
        :files [\".claude/settings.json\" \"~/.claude/settings.json\"]
        :changes {:hooks {:SubagentStop {:enabled false}}}}
       :auto-apply true
       :applied-at #inst \"2026-02-09\"
       :success-rate 1.0}}}"
   :operations
   ["Add workaround (from issue search or manual)"
    "Check if error matches known workaround"
    "Apply workaround automatically if auto-apply true"
    "Track success rate of applied workarounds"]}

  :layer-3-backend-reliability
  {:responsibility "Track backend health and switch when unreliable"
   :location "~/.miniforge/backend_health.edn"
   :metrics
   {:per-backend
    {:claude {:total-invocations 150
              :successful 142
              :failed 8
              :agent-backend-errors 6  ; Vendor bugs
              :task-code-errors 2       ; User code bugs
              :success-rate 0.947
              :recent-failures [#inst "2026-02-09" #inst "2026-02-09"]
              :health :degraded}
     :codex {:total-invocations 20
             :successful 20
             :failed 0
             :success-rate 1.0
             :health :healthy}}}
   :thresholds
   {:healthy "> 95% success rate, < 2 agent-backend errors/day"
    :degraded "90-95% success rate, 2-5 agent-backend errors/day"
    :unhealthy "< 90% success rate, > 5 agent-backend errors/day"}
   :actions
   {:degraded "Warn user, continue with current backend"
    :unhealthy "Auto-switch to best healthy alternative backend"}}}

 :implementation
 {:phase-1-workaround-detection
  {:files-to-create
   ["components/agent-runtime/src/ai/miniforge/agent_runtime/workaround_detector.clj (~200 lines)"
    "- search-vendor-issues: Query GitHub API for error pattern"
    "- parse-workaround: Extract workaround from issue body"
    "- classify-workaround: Determine type (settings, command, env-var)"
    "- should-auto-apply?: Check if safe to apply automatically"]

   :github-api-integration
   "Use gh CLI or GitHub API to search issues:
      gh api search/issues --jq '.items[] | {number, title, body}'
        -f q='repo:anthropics/claude-code classifyHandoffIfNeeded'

    Parse issue body for workaround markers:
      - '## Workaround' section
      - Code blocks with bash commands
      - Configuration snippets
      - 'Disable X' or 'Set Y to Z' patterns"}

  :phase-2-workaround-registry
  {:files-to-create
   ["components/config/src/ai/miniforge/config/workarounds.clj (~150 lines)"
    "- load-workarounds: Read ~/.miniforge/known_workarounds.edn"
    "- save-workaround!: Add workaround to registry"
    "- find-workaround: Match error to known workaround"
    "- apply-workaround!: Execute workaround actions"
    "- track-success!: Update success rate"]

   :workaround-types
   {:settings-modification
    {:description "Modify JSON/EDN settings files"
     :safety :medium
     :requires-backup true
     :example "Disable SubagentStop hooks in .claude/settings.json"}

    :environment-variable
    {:description "Set or unset environment variables"
     :safety :high
     :requires-backup false
     :example "export MINIFORGE_DISABLE_HOOKS=true"}

    :command-execution
    {:description "Run shell command"
     :safety :low
     :requires-approval true
     :example "cp settings_backup.json .claude/settings.json"}

    :backend-switch
    {:description "Change LLM backend"
     :safety :high
     :requires-backup false
     :example "miniforge config backend codex"}}}

  :phase-3-backend-health-tracking
  {:files-to-create
   ["components/agent-runtime/src/ai/miniforge/agent_runtime/backend_health.clj (~200 lines)"
    "- record-invocation: Track each backend call"
    "- record-failure: Record failure type (agent-backend vs task-code)"
    "- calculate-health: Compute health status from metrics"
    "- get-best-alternative: Find healthiest alternative backend"
    "- auto-switch-backend!: Switch when current backend unhealthy"]

   :health-calculation
   "health-score = (successful / total) * 0.7 +
                   (1 - agent-backend-errors / total) * 0.3

    Prioritizes:
    - Overall success rate (70% weight)
    - Absence of vendor bugs (30% weight)

    Ignores task-code-errors (user's responsibility)"}

  :phase-4-integration
  {:files-to-modify
   ["components/agent-runtime/src/ai/miniforge/agent_runtime/interface.clj"
    "- After error classification, check for workarounds"
    "- If agent-backend error, search for workaround"
    "- Apply workaround if found and auto-apply enabled"
    "- Track backend health metrics"
    "- Auto-switch if backend becomes unhealthy"]

   :workflow
   "1. Agent fails with error
    2. Error classifier determines :agent-backend
    3. Workaround detector searches vendor issues
    4. If workaround found:
       - Check registry if already applied
       - If new, ask user or auto-apply
       - Record in registry
    5. Record backend health metrics
    6. If backend unhealthy (< 90% success):
       - Warn: 'Claude backend unhealthy, switching to Codex'
       - Update config: miniforge config backend codex
       - Retry failed operation
    7. Continue execution"}}

