;; Reliability Nines — RN-10: Validation Layer Taxonomy
;; Tier 3 (Governance) — depends on RN-01, RN-02, RN-04
;; No downstream blocks

{:spec/title "RN-10: Implement 5-Layer Validation Taxonomy (L0-L4)"
 :version "1.0.0"
 :type :enhancement
 :priority :medium

 :spec/description
 "Implement the validation layer taxonomy from N4 §3.4. Currently only L2
  (policy validation) exists in gate/policy.clj. Add L0 (syntax/schema),
  L1 (semantic intent), L3 (operational health/quota), and L4 (authorization/
  capability). Enforce ordering invariant: lower layers run first.

  Current state: gate/policy.clj implements L2 policy evaluation.
  Target state: 5 layers with enforced ordering."

 :spec/intent
 {:type :enhancement
  :scope ["components/gate/src/ai/miniforge/gate"
          "components/policy-pack/src/ai/miniforge/policy_pack"]}

 :normative-refs
 {:primary "N4 §3.4 — Validation Layer Taxonomy"
  :secondary ["N2 §9.1 — Workflow spec validation"
              "N10 — Tool action authorization"]}

 :gap-analysis-ref "gap-analysis-reliability-nines.md #10"
 :dag/id :rn-10
 :dag/depends-on [:rn-01 :rn-02 :rn-04]
 :dag/blocks []

 :current-state
 {:L0 "No explicit schema validation layer"
  :L1 "No semantic intent validation layer"
  :L2 "gate/policy.clj — evaluate-severity-cascade, check-policy-pack (exists)"
  :L3 "No operational health/quota layer"
  :L4 "No authorization/capability layer"
  :ordering "No enforced layer ordering"
  :completion "10%"}

 :target-state
 {:layers
  [{:layer :L0 :name "Syntax" :spec "N2"
    :responsibility "Malli schema validation of workflow specs and artifacts"}
   {:layer :L1 :name "Semantic" :spec "N4"
    :responsibility "Intent validation: CREATE/UPDATE/DESTROY/REFACTOR safety"}
   {:layer :L2 :name "Policy" :spec "N4"
    :responsibility "Policy pack rule evaluation (existing)"}
   {:layer :L3 :name "Operational" :spec "N1"
    :responsibility "Health checks, quota enforcement, resource availability"}
   {:layer :L4 :name "Authorization" :spec "N10"
    :responsibility "Capability grants, trust level, action classification"}]
  :ordering "L0 → L1 → L2 → L3 → L4, short-circuit on failure"}

 :implementation
 {:step-1-layer-protocol
  {:title "Define validation layer protocol"
   :files-to-create
   ["components/gate/src/ai/miniforge/gate/layers.clj"]
   :changes
   ["Define ValidationLayer with validate function"
    "Layer registry with ordering enforcement"
    "run-layers function: execute in order, short-circuit on failure"
    "Layer result schema: {:layer keyword :passed? boolean :violations [map]}"]}

  :step-2-L0
  {:title "Implement L0 Syntax layer"
   :changes
   ["Malli schema validation for workflow specs"
    "Malli schema validation for gate inputs"
    "Return violations with schema error details"]}

  :step-3-L1
  {:title "Implement L1 Semantic layer"
   :changes
   ["Extract from existing semantic intent validation"
    "Validate intent type against action safety rules"
    "DESTROY/MIGRATE require explicit confirmation"]}

  :step-4-L3
  {:title "Implement L3 Operational layer"
   :changes
   ["Check degradation mode: block new workflows in safe-mode"
    "Check resource quotas: max concurrent workflows"
    "Check SLO headroom: warn if error budget low"]}

  :step-5-L4
  {:title "Implement L4 Authorization layer"
   :changes
   ["Check autonomy level permits action"
    "Check capability grants for tool actions"
    "Check trust level for target system access"]}

  :step-6-wire
  {:title "Wire layers into existing gate execution"
   :files-to-modify
   ["components/gate/src/ai/miniforge/gate/core.clj"]
   :changes
   ["Replace direct policy evaluation with run-layers pipeline"
    "Existing L2 logic wrapped as PolicyLayer"
    "All gates go through layer pipeline"]}}

 :spec/constraints
 ["L2 (existing policy logic) MUST NOT change behavior"
  "Layer ordering is invariant: L0 < L1 < L2 < L3 < L4"
  "Short-circuit: if L0 fails, L1-L4 don't run"
  "Each layer MUST return structured violations"
  "Follow Polylith interface-only deps"]

 :testing-strategy
 {:unit-tests
  ["Layer ordering enforcement"
   "Short-circuit on L0 failure"
   "Each layer validates and returns violations"
   "L2 backward compat: same behavior as existing policy.clj"]
  :integration-tests
  ["Full pipeline: L0→L1→L2→L3→L4 with valid input"
   "L3 blocks when degradation mode is safe-mode"]}

 :spec/acceptance-criteria
 [{:criterion "5 layers implemented"
   :verification "Each layer has validate function"}
  {:criterion "Ordering enforced"
   :verification "L3 cannot run before L0"}
  {:criterion "Short-circuit on failure"
   :verification "L0 failure skips L1-L4"}
  {:criterion "L2 backward compatible"
   :verification "Existing policy tests pass through layer pipeline"}]

 :estimated-effort "3-5 days"
 :workflow/type :simple}
