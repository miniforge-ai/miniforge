;; =============================================================================
;; Spec: Environment Promotion Pipeline
;; =============================================================================
;;
;; The workflow system currently serializes code artifacts through context maps
;; and relies on an MCP artifact server for handoff. This fails in practice —
;; LLM agents write files via native tools but never call the MCP submission
;; tool. The fundamental fix: the execution environment (Docker container or
;; git worktree) IS the artifact. Phases receive a pointer to the environment,
;; not serialized code. Like CI/CD promotion — the container moves through
;; the pipeline.
;;
;; Discovered during dogfooding: miniforge running M1.3 against a real
;; downstream product repo.
;; Implement phase generated correct Rust code, gates passed, but artifact
;; handoff failed 3x because the LLM never called submit_code_artifact.
;;
;; Current state (after partial implementation):
;;   - runner.clj acquires executor environment before phases — DONE
;;   - implement.clj uses :execution/worktree-path, stores env-id in result — DONE
;;   - context.clj documents the execution context schema — DONE
;;   - execution.clj track-phase-files is a no-op, artifacts capture provenance — DONE
;;   - verify.clj still reads code artifact from phase-results — TODO
;;   - release.clj: assert-implement-artifact! checks :status (not :output) — done
;;     but release executor still has sandbox?/local? conditional branches — TODO
;;   - MCP artifact server still present — TODO
;;
;; Target state:
;;   - All phases operate inside the same executor environment
;;   - Environment-id is the artifact reference between phases
;;   - Event stream carries decisions/evidence/metrics, NOT code
;;   - Code lives in the environment → eventually in the PR
;;   - MCP artifact server removed (no longer needed)

{:spec/title "Environment Promotion Pipeline"
 :spec/description
 "Replace serialized artifact handoff with environment promotion. The workflow
  runner acquires a Docker container (preferred) or git worktree (fallback)
  before the first phase. All phases operate inside this environment. The
  implement agent writes files directly into the environment. Verify runs
  tests in the environment. Release creates the PR from the environment.
  No code flows through the event stream or context maps."

 :spec/intent
 {:type :refactor
  :scope ["components/phase-software-factory/src/ai/miniforge/phase/verify.clj"
          "components/phase-software-factory/src/ai/miniforge/phase/release.clj"
          "components/release-executor/src/ai/miniforge/release_executor"
          "scripts/mcp-artifact-server.bb"
          "bases/cli/src/ai/miniforge/cli/workflow_runner.clj"]}

 :spec/constraints
 ["Executor environment acquired ONCE per workflow, not per phase"
  "Environment-id replaces :code/files as the artifact reference"
  "Event stream carries decisions, evidence, metrics — NOT code"
  "Existing phase :enter/:leave signatures preserved (interceptor contract)"
  "All existing tests must pass after refactor"
  "MCP artifact server can be removed once environment promotion works"]

 :spec/workflow-type :canonical-sdlc
 :workflow/version "2.0.0"

 ;; -------------------------------------------------------------------------
 ;; TASKS
 ;; -------------------------------------------------------------------------

 ;; Already implemented (do not re-implement):
 ;;   :acquire-environment-in-runner — runner.clj acquires/releases env
 ;;   :implement-phase-uses-environment — implement.clj uses :execution/worktree-path
 ;;   :update-context-schema — context.clj and execution.clj updated

 :plan/tasks

 [{:task/id :verify-phase-uses-environment
   :task/description
   "Goal: Verify phase runs tests inside the executor environment, not via a
    tester agent that reads serialized code from phase-results.

    Current behavior to remove:
    - verify.clj reads code artifact from :execution/phase-results :implement :result :output
    - Throws 'Verify phase received no code artifact' when that key is missing
    - Tester agent receives serialized code and writes test files

    Target behavior:
    - Verify phase reads :execution/environment-id and :execution/worktree-path from context
    - Runs the repo's test suite directly in the environment
    - Captures test output and exit code
    - Stores pass/fail + output in phase-results (no code artifact needed)
    - Fails fast if :execution/environment-id is absent from context

    The test command should be inferred from the repo type (bb test for Clojure,
    cargo test for Rust, etc.) or come from the spec's :spec/test-command.

    Acceptance criteria:
    - Tests run inside the executor environment via shell command
    - No serialized code artifact needed as input
    - Phase fails fast if no environment-id in context
    - Test output (stdout/stderr, exit code) captured in phase-results"
   :task/type :implement
   :task/dependencies []}

  {:task/id :release-phase-from-environment
   :task/description
   "Goal: Release phase creates a PR directly from the executor environment,
    without needing serialized code artifacts from implement phase-results.

    The release.clj and release_executor/core.clj currently have conditional
    logic for sandbox vs. local paths, and build workflow state by extracting
    code from implement phase-results. In the new model, the environment
    already has the code — release just needs to git add/commit/push/pr.

    Current behavior to simplify:
    - build-workflow-state extracts code artifacts from implement phase-results
    - execute-release-phase has sandbox?/local? conditional branches
    - step-write-and-stage writes serialized :code/files to disk

    Target behavior:
    - sandbox? is ALWAYS true (environment always exists)
    - build-workflow-state: git-dirty-files is the primary source (not fallback)
    - execute-release-phase: no step-write-and-stage for explicit :code/files
    - Stage whatever the agent wrote (git add -A or git diff --name-only)
    - The environment already has the implementation — just create the PR

    Acceptance criteria:
    - Release creates PR from executor environment
    - No serialized code-artifact input needed
    - sandbox? always true — one code path
    - PR contains exactly what the implement agent wrote"
   :task/type :implement
   :task/dependencies [:verify-phase-uses-environment]}

  {:task/id :remove-mcp-artifact-server
   :task/description
   "Goal: Remove the MCP artifact server — it is no longer needed once agents
    write directly to the executor environment.

    Items to remove:
    - scripts/mcp-artifact-server.bb (delete or archive)
    - MCP server startup/teardown in the CLI workflow runner (if present)
    - artifact-dir temp directory creation in runner
    - References to submit_code_artifact / submit_test_artifact MCP tools
      in any agent prompts or tool registrations

    The event stream and evidence bundle still capture:
    - Phase transitions (started/completed/failed)
    - Agent decisions and reasoning
    - Test results and metrics
    - PR metadata from release

    Code itself is NOT in the event stream — it's in the environment/PR.

    Acceptance criteria:
    - MCP artifact server not started during workflow execution
    - Agents write directly to environment — no artifact submission tool
    - Event stream still captures all non-code evidence"
   :task/type :implement
   :task/dependencies [:release-phase-from-environment]}

  {:task/id :integration-test-environment-promotion
   :task/description
   "Goal: Verify the full environment promotion pipeline works end-to-end.

    Run a small workflow through the full pipeline and confirm:
    1. Environment acquired before plan phase
    2. Implement agent writes to the executor environment (not host)
    3. Verify phase runs tests in the environment
    4. Release creates a PR from the environment
    5. Environment is released after workflow completes (success or failure)

    Failure recovery must also work:
    - If implement fails, environment is still released (try/finally)
    - If verify fails, environment is still released
    - If workflow times out, environment is released

    Acceptance criteria:
    - Full pipeline runs without artifact serialization errors
    - Environment cleanup is reliable (no leaked worktrees/containers)
    - PR diff contains only what the implement agent wrote"
   :task/type :test
   :task/dependencies [:release-phase-from-environment
                       :remove-mcp-artifact-server]}]

 ;; -------------------------------------------------------------------------
 ;; DEPENDENCIES
 ;; -------------------------------------------------------------------------

 :dependencies
 {:verify-phase-uses-environment []
  :release-phase-from-environment [:verify-phase-uses-environment]
  :remove-mcp-artifact-server [:release-phase-from-environment]
  :integration-test-environment-promotion [:release-phase-from-environment
                                           :remove-mcp-artifact-server]}}
