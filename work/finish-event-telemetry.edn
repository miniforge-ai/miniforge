;; =============================================================================
;; Spec: Finish Event Telemetry & Dashboard Live Wiring
;; =============================================================================
;;
;; Goal: When `miniforge workflow run` executes, the dashboard shows real-time
;; progress — phase transitions, agent streaming output, metrics, completion.
;; Dogfood: Run miniforge on THIS spec while watching the dashboard update.
;;
;; Current state: ~40% wired. Event stream core is solid. Plan + implement
;; phases emit events. But verify/review/release are silent, agent streaming
;; doesn't flow to dashboard, and the browser WebSocket handler drops events
;; on the floor due to envelope mismatch.

{:title "Finish Event Telemetry & Dashboard Live Wiring"
 :description "Complete the event telemetry pipeline so the dashboard shows real-time
   workflow progress — phase transitions, agent streaming output, metrics, and completion.
   Five breaks in the pipeline need fixing: silent phases (verify/review/release emit
   zero events), missing streaming callbacks (agent output never reaches subscribers),
   WebSocket envelope mismatch (browser drops events), no browser-side refresh wiring,
   and no event query API for historical data."
 :intent {:type :implement
          :scope ["components/phase/src"
                  "components/web-dashboard/src"
                  "components/web-dashboard/resources/public/js"]}
 :constraints ["Do not change event-stream core — it's already complete"
               "Do not change agent component — it already accepts on-chunk"
               "Use requiring-resolve for optional event-stream dependency"
               "Preserve backward compatibility with existing WebSocket consumers"]
 :workflow/type :standard-sdlc
 :workflow/version "2.0.0"

 ;; ---------------------------------------------------------------------------
 ;; PROBLEM STATEMENT
 ;; ---------------------------------------------------------------------------
 ;;
 ;; Five breaks in the event pipeline prevent live dashboard updates:
 ;;
 ;; 1. SILENT PHASES — verify.clj, review.clj, release.clj emit zero events.
 ;;    Dashboard shows workflow stuck at "implement" forever.
 ;;
 ;; 2. NO STREAMING CALLBACKS — Phases don't create on-chunk callbacks from
 ;;    the event stream. Agent token-by-token output never reaches subscribers.
 ;;    No agent/status events (thinking, generating, validating).
 ;;
 ;; 3. WEBSOCKET ENVELOPE MISMATCH — server.clj sends raw event JSON to
 ;;    browser. Browser expects {type: "event", data: {...}}. The switch
 ;;    statement in app.js falls through to "Unknown message type" for every
 ;;    workflow event.
 ;;
 ;; 4. NO BROWSER-SIDE REFRESH — Browser dispatches CustomEvent("refresh")
 ;;    but nothing listens. No htmx swap, no DOM update, no kanban card move.
 ;;
 ;; 5. NO EVENT QUERY API — Dashboard can't show historical workflow runs.
 ;;    state.clj reconstructs from in-memory event log but there's no REST
 ;;    endpoint exposing it.

 ;; ---------------------------------------------------------------------------
 ;; TASKS
 ;; ---------------------------------------------------------------------------

 :tasks

 [{:task/id :phase-events
   :task/title "Emit phase lifecycle events from all phases"
   :task/phase :implement
   :task/description
   "Add emit-phase-started! and emit-phase-completed! to verify.clj, review.clj,
    and release.clj — matching the pattern already established in plan.clj and
    implement.clj.

    Files to modify:
    - components/phase/src/ai/miniforge/phase/verify.clj
      - enter-verify: Add (emit-phase-started! ctx :verify) at top
      - leave-verify: Add (emit-phase-completed! ctx :verify result) at bottom
    - components/phase/src/ai/miniforge/phase/review.clj
      - enter-review: Add (emit-phase-started! ctx :review) at top
      - leave-review: Add (emit-phase-completed! ctx :review result) at bottom
    - components/phase/src/ai/miniforge/phase/release.clj
      - enter-release: Add (emit-phase-started! ctx :release) at top
      - leave-release: Add (emit-phase-completed! ctx :release result) at bottom

    The emit functions already exist — plan.clj lines 32-51 define them:
      (defn- emit-phase-started! [ctx phase]
        (when-let [es (:event-stream ctx)]
          (let [publish! (requiring-resolve 'ai.miniforge.event-stream.interface/publish!)
                phase-started (requiring-resolve 'ai.miniforge.event-stream.interface/phase-started)]
            (publish! es (phase-started es (:execution/id ctx) phase)))))

    Copy this pattern (or extract to a shared ns if DRY matters).

    Acceptance:
    - All 5 phases (plan, implement, verify, review, release) emit started+completed
    - Events include :phase/outcome (:success/:failure/:skipped) and :phase/duration-ms
    - Existing tests still pass"

  :task/constraints
  ["Do NOT change the phase execution logic — only add event emission"
   "Use requiring-resolve for event-stream dependency (it's optional)"
   "Include duration-ms calculated from System/currentTimeMillis deltas"]}

  {:task/id :agent-streaming
   :task/title "Wire on-chunk streaming callbacks through phases to agents"
   :task/phase :implement
   :task/description
   "Phases receive :event-stream in context but never create streaming callbacks.
    Agents accept :on-chunk in context but phases never set it. Fix this.

    For each phase (plan, implement, verify, review):
    1. In the enter- function, before invoking the agent:
       - Check if :event-stream exists in ctx
       - If so, create a streaming callback:
         (let [on-chunk (when-let [es (:event-stream ctx)]
                          (let [create-cb (requiring-resolve
                                          'ai.miniforge.event-stream.interface/create-streaming-callback)]
                            (create-cb es (:execution/id ctx) (keyword (name phase))
                                       {:print? (not (:quiet ctx)) :quiet? (:quiet ctx)})))]
           (agent/invoke agent task (cond-> ctx on-chunk (assoc :on-chunk on-chunk))))

    2. Also emit agent/status events at key points:
       - Before agent invocation: :status/type :running
       - After successful validation: :status/type :validating
       - During repair: :status/type :repairing

    The create-streaming-callback function already exists at
    event-stream/interface.clj lines 323-353. It returns a
    (fn [{:keys [delta done?]}]) that publishes agent/chunk events.

    Files to modify:
    - components/phase/src/ai/miniforge/phase/plan.clj
    - components/phase/src/ai/miniforge/phase/implement.clj
    - components/phase/src/ai/miniforge/phase/verify.clj
    - components/phase/src/ai/miniforge/phase/review.clj

    Note: release.clj uses release-executor, not an agent — skip it.

    Acceptance:
    - Agent streaming output publishes as :agent/chunk events
    - Chunks flow to event stream subscribers (including dashboard WebSocket)
    - Console output still works (print? flag)
    - :agent/status events emitted at phase boundaries"

   :task/constraints
   ["Use requiring-resolve — event-stream is an optional dependency"
    "Don't break phases that run without an event stream (es = nil case)"
    "Streaming callback agent-id should be the phase keyword (:plan, :implement, etc.)"]}

  {:task/id :ws-envelope
   :task/title "Fix WebSocket message envelope format"
   :task/phase :implement
   :task/description
   "The server sends raw event JSON to browser clients. The browser expects
    messages wrapped in {type: 'event', data: {...}}.

    Fix in server.clj — the subscriber callback created in subscribe-client!
    (around line 81):

    BEFORE:
      (fn [event]
        (http/send! ch (json/generate-string event)))

    AFTER:
      (fn [event]
        (http/send! ch (json/generate-string {:type :event :data event})))

    Also fix the initial state message sent on WebSocket open (around line 174).
    It already sends {:type :init :data ...} which is correct — verify it matches.

    Files to modify:
    - components/web-dashboard/src/ai/miniforge/web_dashboard/server.clj
      - subscribe-client! callback: Wrap event in {:type :event :data event}

    Acceptance:
    - Browser receives {type: 'event', data: {event/type: ..., ...}}
    - Browser's handleWebSocketMessage switch hits 'event' case
    - Init message still works (type: 'init')"

   :task/constraints
   ["Only change the message envelope — don't change event content"
    "Must be backward-compatible with any existing WebSocket consumers"]}

  {:task/id :browser-refresh
   :task/title "Browser handles incoming events and refreshes UI"
   :task/phase :implement
   :task/description
   "The browser dispatches CustomEvent('refresh') on event receipt but nothing
    listens. Wire this up so workflow events trigger htmx partial refreshes.

    In app.js, the handleWebSocketMessage function:

    1. For 'event' type messages — trigger htmx refresh on relevant sections:
       - Find all elements with data-filter-refresh='true' attribute
       - Trigger htmx:load on them (htmx.trigger(el, 'refresh'))
       - This causes htmx to re-fetch their hx-get endpoints

    2. For 'state' type messages — full dashboard refresh:
       - Same as above but refresh ALL htmx-powered sections

    3. For specific event types, add visual feedback:
       - workflow/started: Show toast notification
       - workflow/phase-started: Update status indicator
       - workflow/completed: Show success toast
       - workflow/failed: Show error toast
       - agent/chunk: Append to live output panel (if visible)

    The htmx elements already have the right attributes:
    - #trains-section has hx-get='/api/trains' hx-trigger='refresh from:body'
    - #workflows-content has hx-get='/api/workflows' hx-trigger='refresh from:body'
    - #evidence-content has hx-get='/api/evidence/list' hx-trigger='refresh from:body'

    So dispatching 'refresh' on document.body should already trigger htmx!
    The issue is that handleWebSocketMessage dispatches on document.body but
    htmx listens for 'refresh' events with 'from:body'. Verify this works
    and fix if needed.

    Files to modify:
    - components/web-dashboard/resources/public/js/app.js
      - handleWebSocketMessage: Handle 'event' type properly
      - Add event-specific UI updates

    Acceptance:
    - Workflow events trigger htmx section refreshes
    - Kanban board updates when task status changes
    - Workflow list updates when new workflow starts
    - Toast notifications for major lifecycle events"

   :task/constraints
   ["Use existing htmx refresh mechanism — don't add manual DOM manipulation"
    "Keep it simple — htmx 'refresh from:body' trigger should do most of the work"
    "Toast notifications should auto-dismiss after 5 seconds"]}

  {:task/id :event-query-api
   :task/title "Add REST endpoint for event history query"
   :task/phase :implement
   :task/description
   "Dashboard has no way to show historical workflow events. state.clj has
    get-workflows which reconstructs from event stream, but the workflow list
    view calls it on page load and never again.

    Add /api/events endpoint:

    GET /api/events
      ?workflow-id=uuid     (optional, filter by workflow)
      ?event-type=keyword   (optional, filter by type)
      ?since=iso-timestamp  (optional, events after this time)
      ?limit=100            (optional, max events returned)

    Returns JSON array of events, newest first.

    Also add /api/workflow/:id/events for a specific workflow's event timeline.
    This powers the workflow detail view.

    Files to modify:
    - components/web-dashboard/src/ai/miniforge/web_dashboard/server.clj
      - Add handle-api-events handler
      - Add handle-api-workflow-events handler
      - Wire routes in create-handler

    - components/web-dashboard/src/ai/miniforge/web_dashboard/state.clj
      - Add get-workflow-events function that queries event stream

    Acceptance:
    - GET /api/events returns JSON array of events
    - Filtering by workflow-id, event-type, since works
    - GET /api/workflow/:id/events returns timeline for one workflow
    - Events include all N3 envelope fields"

   :task/constraints
   ["Return events as JSON with keyword keys converted to strings"
    "Limit defaults to 100 to prevent huge responses"
    "Events should be newest-first (reverse chronological)"]}

  {:task/id :dogfood-test
   :task/title "End-to-end dogfood test: run workflow + watch dashboard"
   :task/phase :verify
   :task/description
   "Verify the full pipeline works by running miniforge on a real workflow
    while watching the dashboard. This is the acceptance test for the entire
    event telemetry system.

    Test procedure:
    1. Start dashboard: miniforge dashboard
    2. Open browser to http://localhost:7878
    3. Verify WebSocket connects (green dot)
    4. In separate terminal: miniforge workflow run <spec>
    5. Watch dashboard for:
       a. Workflow appears in workflow list
       b. Phase transitions update in real-time
       c. Agent streaming output visible (if output panel exists)
       d. Kanban board reflects task status changes
       e. Completion/failure shows final state

    Use this spec as the test workflow if possible (dogfood on dogfood).

    Verify in browser console:
    - No 'Unknown message type' warnings
    - Events arrive as {type: 'event', data: {...}}
    - htmx refresh triggers fire on event receipt

    Verify in server logs:
    - Events received on /ws/events
    - Events normalized and published to event stream
    - Subscriber callbacks fire for UI clients

    Verify persistence:
    - Check ~/.miniforge/events/<workflow-id>.edn exists
    - Contains all lifecycle events in order
    - GET /api/events returns the same events

    Acceptance:
    - Dashboard updates in real-time during workflow execution
    - All phases visible as they start/complete
    - Event persistence works
    - WebSocket stays connected throughout
    - No console errors in browser or server"}]

 ;; ---------------------------------------------------------------------------
 ;; ARCHITECTURE NOTES
 ;; ---------------------------------------------------------------------------
 ;;
 ;; Event Flow (after fixes):
 ;;
 ;;   Phase.enter()
 ;;     ├─ emit-phase-started!()          → event-stream/publish!
 ;;     ├─ create-streaming-callback()    → returns on-chunk fn
 ;;     ├─ agent/invoke(task, ctx+on-chunk)
 ;;     │    ├─ LLM streaming            → on-chunk({delta, done?})
 ;;     │    │    └─ publish! agent/chunk  → event-stream
 ;;     │    └─ agent/status events       → event-stream
 ;;     └─ emit-phase-completed!()        → event-stream/publish!
 ;;
 ;;   Event Stream (pub/sub + sinks):
 ;;     ├─ File sink   → ~/.miniforge/events/<wf-id>.edn
 ;;     ├─ Subscriber: dashboard WS client callback
 ;;     │    └─ http/send! {:type :event :data event}
 ;;     │         └─ Browser: handleWebSocketMessage()
 ;;     │              └─ htmx.trigger(body, 'refresh')
 ;;     │                   └─ #workflows-content re-fetches /api/workflows
 ;;     └─ Subscriber: TUI message bridge (if running)
 ;;
 ;; File Inventory (files that need changes):
 ;;
 ;;   Phase components (event emission + streaming):
 ;;     components/phase/src/ai/miniforge/phase/verify.clj
 ;;     components/phase/src/ai/miniforge/phase/review.clj
 ;;     components/phase/src/ai/miniforge/phase/release.clj
 ;;     components/phase/src/ai/miniforge/phase/plan.clj     (add on-chunk)
 ;;     components/phase/src/ai/miniforge/phase/implement.clj (add on-chunk)
 ;;
 ;;   Dashboard server (WebSocket envelope + event API):
 ;;     components/web-dashboard/src/ai/miniforge/web_dashboard/server.clj
 ;;     components/web-dashboard/src/ai/miniforge/web_dashboard/state.clj
 ;;
 ;;   Browser (event handling + refresh):
 ;;     components/web-dashboard/resources/public/js/app.js
 ;;
 ;; Files that should NOT change:
 ;;     components/event-stream/   (already complete)
 ;;     components/agent/          (already accepts on-chunk in context)
 ;;     bases/cli/                 (already creates event streams)

 ;; ---------------------------------------------------------------------------
 ;; DEPENDENCIES
 ;; ---------------------------------------------------------------------------

 :dependencies
 {:phase-events   []
  :agent-streaming [:phase-events]
  :ws-envelope     []
  :browser-refresh [:ws-envelope]
  :event-query-api []
  :dogfood-test    [:phase-events :agent-streaming :ws-envelope :browser-refresh]}}
