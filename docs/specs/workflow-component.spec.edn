;; Workflow Component Implementation Spec
;; ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
;;
;; This spec defines how workflow configurations become live, executable
;; configurations that:
;; 1. Load from EDN files
;; 2. Execute as interpreted DAGs
;; 3. Can be updated by the Meta loop at runtime
;; 4. Integrate with Policy, Heuristic, and Loop components

{:spec-version "1.0.0"
 :created-at "2026-01-21"
 :component "workflow"
 :phase "Phase 2"

 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Overview
 ;; ──────────────────────────────────────────────────────────────────────────
 
 :overview
 "The Workflow component is the execution engine for configurable SDLC flows.

  Key responsibilities:
  - Load workflow configs from EDN files
  - Validate configs against Malli schema
  - Execute workflows by interpreting the DAG
  - Track state during execution (current phase, budgets, metrics)
  - Integrate with Policy component for gate evaluation
  - Store/retrieve workflows via Heuristic component
  - Enable Meta loop to propose and activate new workflows

  This is the 'interpreter' that makes workflow configs executable."

 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Component Structure (Polylith)
 ;; ──────────────────────────────────────────────────────────────────────────
 
 :structure
 {:component "components/workflow"

  :namespaces
  {:interface "ai.miniforge.workflow.interface"
   :core "ai.miniforge.workflow.core"
   :loader "ai.miniforge.workflow.loader"
   :executor "ai.miniforge.workflow.executor"
   :state "ai.miniforge.workflow.state"
   :validator "ai.miniforge.workflow.validator"}

  :resources
  {:schemas "components/workflow/resources/schemas/workflow.edn"
   :configs "components/workflow/resources/workflows/*.edn"
   :active "~/.miniforge/workflows/active.edn"}

  :dependencies
  [:policy      ; Gate evaluation
   :heuristic   ; Workflow storage/versioning
   :schema      ; Malli validation
   :llm]}       ; Agent invocation
 
 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Public API (interface.clj)
 ;; ──────────────────────────────────────────────────────────────────────────
 
 :api
 {:load-workflow
  {:doc "Load workflow config from file or heuristic store"
   :params [{:name :workflow-id :type keyword?}
            {:name :version :type string? :optional true}
            {:name :opts :type map? :optional true}]
   :returns :workflow/config
   :example
   "(load-workflow :canonical-sdlc-v1 \"1.0.0\")
    ;=> {:workflow/id :canonical-sdlc-v1 :workflow/phases [...]}"}

  :execute-workflow
  {:doc "Execute a workflow on an input artifact"
   :params [{:name :workflow :type :workflow/config}
            {:name :input :type :artifact/spec}
            {:name :opts :type map? :optional true}]
   :returns :workflow/execution
   :example
   "(execute-workflow canonical-workflow user-spec)
    ;=> {:execution/id #uuid \"...\"
    ;    :execution/status :completed
    ;    :execution/phases [{:phase :input :status :passed} ...]
    ;    :execution/metrics {...}}"}

  :get-active-workflow
  {:doc "Get the currently active workflow for a task type"
   :params [{:name :task-type :type keyword?}]
   :returns :workflow/config
   :example
   "(get-active-workflow :feature)
    ;=> canonical-sdlc-v1"}

  :set-active-workflow
  {:doc "Set the active workflow for a task type (Meta loop uses this)"
   :params [{:name :task-type :type keyword?}
            {:name :workflow-id :type keyword?}
            {:name :version :type string?}]
   :returns boolean?
   :example
   "(set-active-workflow :bugfix :lean-sdlc-v1 \"1.0.0\")
    ;=> true"}

  :save-workflow
  {:doc "Save a new workflow config (Meta loop proposes new configs)"
   :params [{:name :workflow :type :workflow/config}]
   :returns uuid?
   :example
   "(save-workflow {:workflow/id :canonical-sdlc-v1.1
                    :workflow/version \"1.1.0\"
                    :workflow/phases [...]})
    ;=> #uuid \"...\""}

  :list-workflows
  {:doc "List all available workflows"
   :params []
   :returns [:vector :workflow/id]
   :example
   "(list-workflows)
    ;=> [:canonical-sdlc-v1 :lean-sdlc-v1 :rigorous-sdlc-v1]"}

  :compare-workflows
  {:doc "Compare metrics between workflow executions"
   :params [{:name :execution-ids :type [:vector uuid?]}]
   :returns :workflow/comparison
   :example
   "(compare-workflows [exec-1-id exec-2-id])
    ;=> {:workflows [{:id :canonical-sdlc-v1 :avg-time 45 :success-rate 0.8}
    ;                {:id :lean-sdlc-v1 :avg-time 25 :success-rate 0.75}]
    ;    :recommendation :lean-sdlc-v1}"}}

 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Core Implementation
 ;; ──────────────────────────────────────────────────────────────────────────
 
 :implementation
 {:loader
  {:doc "Load and validate workflow configs"
   :functions
   {:load-from-file
    "(defn load-from-file [path]
       (-> path slurp edn/read-string validate-workflow))"

    :load-from-heuristic
    "(defn load-from-heuristic [workflow-id version]
       (heuristic/get-heuristic workflow-id version))"

    :validate-workflow
    "(defn validate-workflow [config]
       (let [schema (load-schema)]
         (if (m/validate schema config)
           config
           (throw (ex-info \"Invalid workflow config\"
                          {:errors (m/explain schema config)})))))"}}

  :executor
  {:doc "Execute workflow DAG with state management"
   :functions
   {:execute
    "(defn execute [workflow input opts]
       (let [state (init-state workflow input)]
         (loop [current-phase (first-phase workflow)
                state state]
           (if (terminal-phase? current-phase)
             (finalize-execution state)
             (let [result (execute-phase current-phase state)
                   next-phase (select-next-phase result)]
               (recur next-phase (update-state state result)))))))"

    :execute-phase
    "(defn execute-phase [phase state]
       ;; 1. Check budget
       ;; 2. Run inner loop (generate -> validate -> repair)
       ;; 3. Run review loop (if configured)
       ;; 4. Evaluate gates
       ;; 5. Collect metrics
       ;; 6. Return result
       {:phase/id (:phase/id phase)
        :phase/status :passed
        :phase/iterations 3
        :phase/metrics {...}})"

    :select-next-phase
    "(defn select-next-phase [result]
       ;; Interpret phase/next transitions
       ;; Support conditional branching
       ;; Handle parallel phases (future)
       (first (filter #(gates-pass? % result)
                     (:phase/next result))))"}}

  :state
  {:doc "Manage workflow execution state"
   :functions
   {:init-state
    "(defn init-state [workflow input]
       {:execution/id (random-uuid)
        :execution/workflow-id (:workflow/id workflow)
        :execution/start-time (Instant/now)
        :execution/current-phase nil
        :execution/phases []
        :execution/artifact input
        :execution/budget-used {:tokens 0 :time 0 :iterations 0}
        :execution/metrics []})"

    :update-state
    "(defn update-state [state phase-result]
       (-> state
           (update :execution/phases conj phase-result)
           (update :execution/budget-used merge-budgets (:budget-used phase-result))
           (update :execution/metrics conj (:metrics phase-result))
           (assoc :execution/artifact (:artifact phase-result))))"

    :finalize-execution
    "(defn finalize-execution [state]
       (assoc state
              :execution/end-time (Instant/now)
              :execution/status :completed
              :execution/total-time (calculate-duration state)
              :execution/summary (summarize-metrics state)))"}}

  :validator
  {:doc "Validate workflow configs and DAG correctness"
   :functions
   {:validate-dag
    "(defn validate-dag [workflow]
       ;; Check for cycles
       ;; Verify all phase/next targets exist
       ;; Ensure single start node
       ;; Ensure reachability of all phases
       (when-let [errors (check-dag-structure workflow)]
         (throw (ex-info \"Invalid DAG\" {:errors errors}))))"

    :validate-gates
    "(defn validate-gates [phase]
       ;; Ensure all gate types are known
       ;; Verify gate configs are valid
       (policy/validate-gate-configs (:phase/gates phase)))"

    :validate-budgets
    "(defn validate-budgets [workflow]
       ;; Check phase budgets sum <= total budget
       ;; Ensure all budgets are positive
       (when (> (sum-phase-budgets workflow)
               (get-in workflow [:workflow/config :max-total-tokens]))
         (throw (ex-info \"Budget overflow\" {...}))))"}}

  :integration
  {:policy-component
   {:usage "Evaluate gates at phase boundaries"
    :example
    "(defn evaluate-phase-gates [phase artifact]
       (policy/evaluate artifact
                       (:phase/id phase)
                       (:phase/gates phase)))"}

   :heuristic-component
   {:usage "Store/retrieve workflows as versioned heuristics"
    :example
    "(defn save-workflow-as-heuristic [workflow]
       (heuristic/save-heuristic
         (:workflow/id workflow)
         (:workflow/version workflow)
         workflow))"}

   :loop-component
   {:usage "Execute inner loops within phases"
    :example
    "(defn run-inner-loop [phase artifact agent]
       (loop-engine/execute
         {:max-iterations (get-in phase [:phase/inner-loop :max-iterations])
          :validator (get-validator phase)
          :repairer (get-repairer phase agent)
          :artifact artifact}))"}

   :llm-component
   {:usage "Invoke agents for phase actions"
    :example
    "(defn invoke-agent [agent action artifact context]
       (llm/chat agent
                 (build-prompt action artifact)
                 {:context context}))"}}}

 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Live Configuration
 ;; ──────────────────────────────────────────────────────────────────────────
 
 :live-configuration
 {:active-workflow-file
  {:location "~/.miniforge/workflows/active.edn"
   :format
   "{:feature :canonical-sdlc-v1
     :bugfix :lean-sdlc-v1
     :refactor :canonical-sdlc-v1
     :component :canonical-sdlc-v1}"
   :doc "Maps task types to active workflow IDs"}

  :hot-reload
  {:description "Workflows can be updated without restarting miniforge"
   :mechanism
   "1. Meta loop proposes new workflow config
    2. Saves to ~/.miniforge/workflows/proposed-v1.1.0.edn
    3. Validates config (schema + DAG)
    4. Updates active.edn to point to new version
    5. Next task uses new workflow
    6. Old executions continue with their original workflow"}

  :meta-loop-workflow-update
  {:description "Meta loop can self-update workflow configs"
   :steps
   ["1. Observe: Collect metrics from recent workflow executions"
    "2. Analyze: Identify bottleneck phases (review takes 40% of time)"
    "3. Propose: Generate new workflow config (reduce review rounds)"
    "4. Validate: Check schema + DAG correctness"
    "5. Save: Write to heuristic store with new version"
    "6. Experiment: A/B test by routing 50% of tasks to new version"
    "7. Measure: Compare metrics (success rate, time, cost)"
    "8. Decide: If better, update active.edn to make it default"
    "9. Version: Increment version (1.0.0 -> 1.1.0)"]

   :example-mutation
   {:before
    "{:phase/id :review
      :phase/review-loop {:max-rounds 3}}"
    :after
    "{:phase/id :review
      :phase/review-loop {:max-rounds 2}}  ; Reduced to save time"}

   :safety
   ["Always validate before activating"
    "Keep old versions available for rollback"
    "Log all config changes for audit"
    "Gradual rollout (A/B test before full deployment)"]}}

