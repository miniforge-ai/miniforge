 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Future Explorations (Systems Thinking)
 ;; ──────────────────────────────────────────────────────────────────────────

 :future-explorations
 [{:concept "Petri Nets"
   :questions
   ["Can we detect deadlocks in workflow configs?"
    "Can we prove liveness (every workflow eventually completes)?"
    "Can we calculate reachability (which phases are reachable from input)?"]
   :tools ["Petri net simulators" "State space analysis"]}

  {:concept "Queuing Theory"
   :questions
   ["What's the optimal review queue size?"
    "How do we balance parallel agents vs sequential?"
    "What's the expected wait time at each phase?"]
   :tools ["M/M/1 queue models" "Little's Law"]}

  {:concept "Constraint Programming"
   :questions
   ["Can we find the optimal workflow via constraint solving?"
    "What are the hard constraints (gates) vs soft (preferences)?"
    "Can we auto-generate workflows from constraints?"]
   :tools ["MiniZinc" "Prolog" "Answer Set Programming"]}

  {:concept "Genetic Algorithms"
   :questions
   ["Can we evolve workflows through mutation and selection?"
    "What's the fitness function (time? quality? cost)?"
    "Can we discover novel workflows humans wouldn't design?"]
   :tools ["Genetic programming" "Evolutionary algorithms"]}

  {:concept "Reinforcement Learning"
   :questions
   ["Can an RL agent learn optimal phase transitions?"
    "What's the reward function (successful merge? low bugs)?"
    "Can we learn which workflow to use for which task type?"]
   :tools ["Q-learning" "Policy gradient methods"]}]

