;; Workflow Configuration Specification
;; ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
;;
;; This spec defines how miniforge workflows are represented as configurable
;; DAG/graphs in EDN. The workflow itself is data, not code.
;;
;; Inspiration: Petri nets, logistics flows, supply chain optimization
;;
;; Key Concept: The Meta loop can propose and test new workflow configurations
;; to find optimal SDLC flows, just as it optimizes prompts and thresholds.

{:spec-version "1.0.0"
 :created-at "2026-01-21"
 :author "miniforge.ai"

 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Overview
 ;; ──────────────────────────────────────────────────────────────────────────

 :overview
 "Workflows define how artifacts flow through miniforge's outer loop.

  Think of workflows as:
  - Petri nets: Phases are places, agents are transitions, artifacts are tokens
  - Logistics: Artifacts move through processing stations (phases)
  - Supply chains: Optimizing flow to minimize cost, maximize quality

  The Meta loop experiments with different workflow configurations to find
  optimal flows for different task types."

 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Schema (Malli)
 ;; ──────────────────────────────────────────────────────────────────────────

 :schema
 {:workflow/id keyword?
  :workflow/version string?  ; Semantic version (1.0.0)
  :workflow/name string?
  :workflow/description string?
  :workflow/created-at inst?
  :workflow/task-types [:vector keyword?]  ; [:feature :bugfix :refactor]

  ;; Phases define the DAG nodes
  :workflow/phases
  [:vector
   {:phase/id keyword?
    :phase/name string?
    :phase/agent keyword?  ; Which agent handles this phase
    :phase/actions [:vector keyword?]  ; Actions the agent performs

    ;; Inner loop configuration
    :phase/inner-loop
    {:max-iterations {:min int? :max int?}
     :validation-steps [:vector keyword?]
     :repair-strategy keyword?}

    ;; Review loops (multi-agent within a phase)
    :phase/review-loop
    [:maybe
     {:reviewers [:vector keyword?]  ; Agent types that review
      :required-approvals int?
      :max-rounds int?}]

    ;; Gates that must pass before next phase
    :phase/gates [:vector keyword?]

    ;; Budget constraints for this phase
    :phase/budget
    {:tokens int?
     :time-seconds int?
     :iterations int?}

    ;; Transition logic
    :phase/next [:vector  ; Multiple possible next phases
                 {:target keyword?  ; Target phase ID
                  :condition [:maybe keyword?]  ; Optional gate/condition
                  :probability [:maybe double?]}]  ; For A/B testing

    ;; Metrics to collect
    :phase/metrics [:vector keyword?]}]

  ;; Edges can be explicit or implicit (via phase/next)
  :workflow/edges
  [:vector
   {:from keyword?
    :to keyword?
    :condition [:maybe keyword?]
    :label [:maybe string?]}]

  ;; Global workflow configuration
  :workflow/config
  {:parallel-phases [:maybe [:vector keyword?]]  ; Phases that can run in parallel
   :failure-strategy keyword?  ; :retry :skip :abort
   :max-total-iterations int?
   :max-total-time-seconds int?
   :max-total-tokens int?}

  ;; Metrics collected for workflow comparison
  :workflow/metrics
  {:success-rate [:maybe double?]
   :avg-iterations int?
   :avg-time-seconds int?
   :avg-tokens-used int?
   :avg-repair-cycles int?
   :test-coverage-achieved [:maybe double?]
   :bugs-caught-in-review int?
   :bugs-caught-in-ci int?
   :bugs-in-production int?}}

 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Canonical Workflow: SDLC v1.0.0
 ;; ──────────────────────────────────────────────────────────────────────────

 :canonical-workflow
 {:workflow/id :canonical-sdlc-v1
  :workflow/version "1.0.0"
  :workflow/name "Canonical SDLC Flow"
  :workflow/description
  "The foundational workflow based on traditional SDLC with inner loops,
   gates, and TDD. This is the starting point for Meta loop optimization."
  :workflow/created-at #inst "2026-01-21"
  :workflow/task-types [:feature :component :refactor]

  :workflow/phases
  [;; Phase 0: Input
   {:phase/id :input
    :phase/name "Input Validation"
    :phase/agent :validator
    :phase/actions [:validate-spec :extract-requirements]
    :phase/inner-loop {:max-iterations 3
                       :validation-steps [:schema-valid :requirements-complete]
                       :repair-strategy :clarify-requirements}
    :phase/gates [:spec-schema-valid :requirements-clear]
    :phase/budget {:tokens 5000 :time-seconds 60 :iterations 3}
    :phase/next [{:target :plan}]
    :phase/metrics [:validation-time :spec-quality-score]}

   ;; Phase 1: Plan
   {:phase/id :plan
    :phase/name "Implementation Planning"
    :phase/agent :planner
    :phase/actions [:analyze-requirements :create-task-breakdown :estimate-effort]
    :phase/inner-loop {:max-iterations 5
                       :validation-steps [:plan-complete :tasks-well-defined]
                       :repair-strategy :refine-plan}
    :phase/review-loop {:reviewers [:pm-reviewer]
                        :required-approvals 1
                        :max-rounds 3}
    :phase/gates [:plan-complete :plan-approved :tasks-well-defined]
    :phase/budget {:tokens 10000 :time-seconds 120 :iterations 5}
    :phase/next [{:target :design}]
    :phase/metrics [:plan-clarity-score :tasks-count :review-rounds]}

   ;; Phase 2: Design
   {:phase/id :design
    :phase/name "Architecture Design"
    :phase/agent :designer
    :phase/actions [:design-architecture :define-interfaces :plan-dependencies]
    :phase/inner-loop {:max-iterations 5
                       :validation-steps [:design-complete :no-circular-deps]
                       :repair-strategy :adjust-design}
    :phase/review-loop {:reviewers [:dev-reviewer]
                        :required-approvals 1
                        :max-rounds 3}
    :phase/gates [:design-complete :architecture-sound :no-circular-dependencies]
    :phase/budget {:tokens 15000 :time-seconds 180 :iterations 5}
    :phase/next [{:target :test-planning}]
    :phase/metrics [:design-quality-score :complexity-score :review-rounds]}

   ;; Phase 3: Test Planning
   {:phase/id :test-planning
    :phase/name "Test Plan Creation"
    :phase/agent :test-planner
    :phase/actions [:identify-test-cases :define-coverage-targets :plan-assertions]
    :phase/inner-loop {:max-iterations 5
                       :validation-steps [:test-plan-complete :coverage-defined]
                       :repair-strategy :add-test-cases}
    :phase/review-loop {:reviewers [:pm-reviewer :dev-reviewer :test-reviewer]
                        :required-approvals 3
                        :max-rounds 3}
    :phase/gates [:test-plan-complete :coverage-targets-defined :approved-by-reviewers]
    :phase/budget {:tokens 12000 :time-seconds 150 :iterations 5}
    :phase/next [{:target :implement-tests}]
    :phase/metrics [:test-case-count :coverage-target :review-rounds]}

   ;; Phase 4: Implement Tests
   {:phase/id :implement-tests
    :phase/name "Test Implementation"
    :phase/agent :tester
    :phase/actions [:generate-test-code :validate-syntax :validate-lint]
    :phase/inner-loop {:max-iterations 10
                       :validation-steps [:syntax-valid :lint-clean :tests-compile]
                       :repair-strategy :fix-test-errors}
    :phase/gates [:syntax-valid :lint-clean :tests-compile]
    :phase/budget {:tokens 20000 :time-seconds 300 :iterations 10}
    :phase/next [{:target :implement-code}]
    :phase/metrics [:test-files-created :test-assertions-count :repair-cycles]}

   ;; Phase 5: Implement Code (TDD)
   {:phase/id :implement-code
    :phase/name "Code Implementation"
    :phase/agent :implementer
    :phase/actions [:generate-code :run-tests :validate-lint]
    :phase/inner-loop {:max-iterations 15
                       :validation-steps [:tests-pass :syntax-valid :lint-clean]
                       :repair-strategy :fix-code-errors}
    :phase/gates [:syntax-valid :lint-clean :tests-pass :no-debug-statements]
    :phase/budget {:tokens 30000 :time-seconds 600 :iterations 15}
    :phase/next [{:target :verify}]
    :phase/metrics [:code-files-created :lines-of-code :test-pass-rate :repair-cycles]}

   ;; Phase 6: Verify
   {:phase/id :verify
    :phase/name "Comprehensive Verification"
    :phase/agent :tester
    :phase/actions [:run-full-test-suite :generate-coverage-report :check-thresholds]
    :phase/inner-loop {:max-iterations 5
                       :validation-steps [:all-tests-pass :coverage-threshold-met]
                       :repair-strategy :add-missing-tests}
    :phase/gates [:all-tests-pass :coverage-threshold-met :no-flaky-tests]
    :phase/budget {:tokens 10000 :time-seconds 300 :iterations 5}
    :phase/next [{:target :review}]
    :phase/metrics [:test-count :coverage-achieved :test-duration]}

   ;; Phase 7: Review
   {:phase/id :review
    :phase/name "Code Review"
    :phase/agent :reviewer
    :phase/actions [:validate-lint :check-stratification :verify-docs :check-coverage]
    :phase/inner-loop {:max-iterations 10
                       :validation-steps [:lint-clean :stratification-valid :docs-complete]
                       :repair-strategy :fix-review-issues}
    :phase/gates [:lint-clean :coverage-threshold-met :stratification-valid
                  :docs-complete :reviewer-approved]
    :phase/budget {:tokens 15000 :time-seconds 400 :iterations 10}
    :phase/next [{:target :release}]
    :phase/metrics [:review-issues-found :repair-cycles :approval-time]}

   ;; Phase 8: Release
   {:phase/id :release
    :phase/name "Pull Request Release"
    :phase/agent :release-manager
    :phase/actions [:create-branch :commit-changes :push-remote :create-pr :monitor-ci]
    :phase/inner-loop {:max-iterations 5
                       :validation-steps [:ci-pass :no-conflicts]
                       :repair-strategy :fix-ci-failures}
    :phase/gates [:ci-lint-pass :ci-test-pass :ci-build-pass
                  :no-merge-conflicts :pr-approved]
    :phase/budget {:tokens 5000 :time-seconds 1800 :iterations 5}
    :phase/next [{:target :observe}]
    :phase/metrics [:ci-runs :ci-failures :pr-comments :time-to-merge]}

   ;; Phase 9: Observe
   {:phase/id :observe
    :phase/name "Post-Merge Observation"
    :phase/agent :observer
    :phase/actions [:collect-metrics :analyze-outcomes :generate-learnings]
    :phase/inner-loop {:max-iterations 1
                       :validation-steps [:metrics-collected]
                       :repair-strategy :none}
    :phase/gates [:metrics-collected]
    :phase/budget {:tokens 5000 :time-seconds 120 :iterations 1}
    :phase/next [{:target :meta-loop}]
    :phase/metrics [:total-iterations :total-tokens :total-time :success-outcome]}]

  :workflow/config
  {:parallel-phases []  ; Future: [:implement-tests :generate-docs]
   :failure-strategy :retry
   :max-total-iterations 100
   :max-total-time-seconds 7200  ; 2 hours
   :max-total-tokens 200000}

  :workflow/metrics
  {:success-rate nil  ; Populated after runs
   :avg-iterations nil
   :avg-time-seconds nil
   :avg-tokens-used nil
   :avg-repair-cycles nil
   :test-coverage-achieved nil
   :bugs-caught-in-review nil
   :bugs-caught-in-ci nil
   :bugs-in-production nil}}

 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Alternative Workflow Examples (for Meta loop to explore)
 ;; ──────────────────────────────────────────────────────────────────────────

 :alternative-workflows
 [;; Lean Flow: Fewer review loops, faster iteration
  {:workflow/id :lean-sdlc-v1
   :workflow/version "1.0.0"
   :workflow/name "Lean SDLC Flow"
   :workflow/description
   "Minimizes review loops and phases for rapid iteration. Hypothesis: Works
    better for small, isolated changes where context is clear."
   :workflow/phases
   [;; Combines Plan + Design into single phase
    {:phase/id :plan-design
     :phase/name "Planning & Design"
     :phase/agent :designer
     :phase/review-loop {:reviewers [:dev-reviewer] :required-approvals 1 :max-rounds 2}
     :phase/next [{:target :implement-all}]}
    ;; Combines Test + Code implementation (true TDD)
    {:phase/id :implement-all
     :phase/name "TDD Implementation"
     :phase/agent :implementer
     :phase/next [{:target :review}]}
    ;; Single review phase
    {:phase/id :review
     :phase/name "Final Review"
     :phase/agent :reviewer
     :phase/next [{:target :release}]}
    {:phase/id :release
     :phase/name "Release"
     :phase/agent :release-manager
     :phase/next [{:target :observe}]}
    {:phase/id :observe
     :phase/name "Observe"
     :phase/agent :observer
     :phase/next [{:target :meta-loop}]}]}

  ;; Rigorous Flow: More review loops, higher quality bar
  {:workflow/id :rigorous-sdlc-v1
   :workflow/version "1.0.0"
   :workflow/name "Rigorous SDLC Flow"
   :workflow/description
   "Adds extra validation phases and review loops. Hypothesis: Works better
    for critical systems where bugs are expensive."
   :workflow/phases
   [;; Adds security review phase
    {:phase/id :security-review
     :phase/name "Security Analysis"
     :phase/agent :security-reviewer
     :phase/actions [:check-vulnerabilities :validate-inputs :check-secrets]
     :phase/next [{:target :implement-code}]}
    ;; Adds performance benchmarking phase
    {:phase/id :benchmark
     :phase/name "Performance Benchmarking"
     :phase/agent :performance-tester
     :phase/actions [:run-benchmarks :check-regression]
     :phase/next [{:target :review}]}]}

  ;; Concurrent Flow: Parallelizes independent phases
  {:workflow/id :concurrent-sdlc-v1
   :workflow/version "1.0.0"
   :workflow/name "Concurrent SDLC Flow"
   :workflow/description
   "Runs independent phases in parallel. Hypothesis: Reduces total wall-clock
    time at the cost of higher token usage."
   :workflow/config
   {:parallel-phases [[:implement-tests :generate-docs]
                      [:verify :security-scan]]}}]

 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Meta Loop Integration
 ;; ──────────────────────────────────────────────────────────────────────────

 :meta-loop-integration
 {:description
  "The Meta loop treats workflows as heuristics to be optimized."

  :workflow-experiments
  [{:experiment/id "compare-canonical-vs-lean"
    :experiment/workflows [:canonical-sdlc-v1 :lean-sdlc-v1]
    :experiment/task-types [:small-feature :bugfix]
    :experiment/sample-size 20
    :experiment/metrics [:success-rate :avg-time :avg-tokens :bugs-in-ci]
    :experiment/hypothesis
    "Lean flow is faster for small changes without sacrificing quality"}

   {:experiment/id "test-parallel-phases"
    :experiment/workflows [:canonical-sdlc-v1 :concurrent-sdlc-v1]
    :experiment/task-types [:feature]
    :experiment/sample-size 10
    :experiment/metrics [:wall-clock-time :total-tokens]
    :experiment/hypothesis
    "Parallel phases reduce time by 30% with acceptable token increase"}]

  :workflow-evolution
  {:step-1 "Observe: Collect metrics from runs using current workflow"
   :step-2 "Analyze: Identify bottlenecks (which phases take longest? most repairs?)"
   :step-3 "Propose: Generate new workflow variant (e.g., merge phases, reorder, add/remove reviews)"
   :step-4 "Test: A/B test new workflow on real tasks"
   :step-5 "Measure: Compare metrics (success rate, time, tokens, bugs)"
   :step-6 "Promote: If better, version and activate new workflow"}

  :petri-net-analogy
  {:places "Phases (states where artifacts exist)"
   :transitions "Agents (actions that transform artifacts)"
   :tokens "Artifacts (code, tests, docs flowing through)"
   :arcs "phase/next (allowed flows)"
   :guards "Gates (conditions for transition firing)"
   :optimization "Find minimal path with maximum quality"}

  :supply-chain-analogy
  {:stations "Phases (processing stations)"
   :operations "Agent actions (value-add operations)"
   :inventory "Artifacts (work-in-progress)"
   :throughput "Tasks per hour"
   :quality "Bugs escaped to production"
   :cost "Token usage + time"
   :optimization "Minimize cost, maximize quality, maximize throughput"}}

