;; Workflow Component API Specification
;; ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
;;
;; Structured API specification for the Workflow component.
;; This defines the public interface for loading, executing, and managing workflows.

{:spec-version "1.0.0"
 :created-at "2026-01-21"
 :component "workflow"
 :phase "Phase 2"

 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Component Structure
 ;; ──────────────────────────────────────────────────────────────────────────

 :structure
 {:component "components/workflow"

  :namespaces
  {:interface "ai.miniforge.workflow.interface"
   :core "ai.miniforge.workflow.core"
   :loader "ai.miniforge.workflow.loader"
   :executor "ai.miniforge.workflow.executor"
   :state "ai.miniforge.workflow.state"
   :validator "ai.miniforge.workflow.validator"}

  :resources
  {:schemas "components/workflow/resources/schemas/workflow.edn"
   :configs "components/workflow/resources/workflows/*.edn"
   :active "~/.miniforge/workflows/active.edn"}

  :dependencies
  [:policy      ; Gate evaluation
   :heuristic   ; Workflow storage/versioning
   :schema      ; Malli validation
   :llm]}       ; Agent invocation

 ;; ──────────────────────────────────────────────────────────────────────────
 ;; Public API
 ;; ──────────────────────────────────────────────────────────────────────────

 :api
 {:load-workflow
  {:doc "Load workflow config from file or heuristic store"
   :params [{:name :workflow-id :type keyword?}
            {:name :version :type string? :optional true}
            {:name :opts :type map? :optional true}]
   :returns :workflow/config
   :example
   "(load-workflow :canonical-sdlc-v1 \"1.0.0\")
    ;=> {:workflow/id :canonical-sdlc-v1 :workflow/phases [...]}"}

  :execute-workflow
  {:doc "Execute a workflow on an input artifact"
   :params [{:name :workflow :type :workflow/config}
            {:name :input :type :artifact/spec}
            {:name :opts :type map? :optional true}]
   :returns :workflow/execution
   :example
   "(execute-workflow canonical-workflow user-spec)
    ;=> {:execution/id #uuid \"...\"
    ;    :execution/status :completed
    ;    :execution/phases [{:phase :input :status :passed} ...]
    ;    :execution/metrics {...}}"}

  :get-active-workflow
  {:doc "Get the currently active workflow for a task type"
   :params [{:name :task-type :type keyword?}]
   :returns :workflow/config
   :example
   "(get-active-workflow :feature)
    ;=> canonical-sdlc-v1"}

  :set-active-workflow
  {:doc "Set the active workflow for a task type (Meta loop uses this)"
   :params [{:name :task-type :type keyword?}
            {:name :workflow-id :type keyword?}
            {:name :version :type string?}]
   :returns boolean?
   :example
   "(set-active-workflow :bugfix :lean-sdlc-v1 \"1.0.0\")
    ;=> true"}

  :save-workflow
  {:doc "Save a new workflow config (Meta loop proposes new configs)"
   :params [{:name :workflow :type :workflow/config}]
   :returns uuid?
   :example
   "(save-workflow {:workflow/id :canonical-sdlc-v1.1
                    :workflow/version \"1.1.0\"
                    :workflow/phases [...]})
    ;=> #uuid \"...\""}

  :list-workflows
  {:doc "List all available workflows"
   :params []
   :returns [:vector :workflow/id]
   :example
   "(list-workflows)
    ;=> [:canonical-sdlc-v1 :lean-sdlc-v1 :rigorous-sdlc-v1]"}

  :compare-workflows
  {:doc "Compare metrics between workflow executions"
   :params [{:name :execution-ids :type [:vector uuid?]}]
   :returns :workflow/comparison
   :example
   "(compare-workflows [exec-1-id exec-2-id])
    ;=> {:workflows [{:id :canonical-sdlc-v1 :avg-time 45 :success-rate 0.8}
    ;                {:id :lean-sdlc-v1 :avg-time 25 :success-rate 0.75}]
    ;    :recommendation :lean-sdlc-v1}"}}}
