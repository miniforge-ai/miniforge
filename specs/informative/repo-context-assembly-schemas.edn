;; repo-context-assembly.spec.edn
;; WIP schemas for Repository Intelligence and Context Assembly (N1 §2.27–§2.30, §11)
;; Canonical spec: specs/normative/N1-architecture.md
;; Status: Draft — aligns with N1 0.4.0-draft

{:spec/id    :repo-context-assembly
 :spec/title "Repository Intelligence and Context Assembly"
 :spec/version "0.1.0-draft"
 :spec/date  #inst "2026-03-04T00:00:00.000-00:00"
 :spec/n1-sections ["§2.27" "§2.28" "§2.29" "§2.30" "§11"]

 ;; ── Range (§2.27.2) ──────────────────────────────────────────────────────────
 ;; Atomic unit of content-addressed code citation.
 ;; Normative: UTF-8, 1-based inclusive lines, LF-normalized, blob-sha over normalized content.
 :schemas/range
 {:range/path       {:type :string   :required true  :doc "Repo-relative file path"}
  :range/blob-sha   {:type :string   :required true  :doc "Content hash of LF-normalized UTF-8"}
  :range/start-line {:type :int      :required true  :doc "1-based, inclusive"}
  :range/end-line   {:type :int      :required true  :doc "1-based, inclusive"}
  :range/start-byte {:type :int      :required false :doc "Byte offset, post-normalization"}
  :range/end-byte   {:type :int      :required false :doc "Byte offset, post-normalization"}}

 ;; ── File Record (§2.27.1) ────────────────────────────────────────────────────
 :schemas/file-record
 {:file/path          {:type :string   :required true}
  :file/blob-sha      {:type :string   :required true}
  :file/lang          {:type :keyword  :required true  :doc ":ts :clojure :python :go :rust ..."}
  :file/size-bytes    {:type :int      :required true}
  :file/is-generated? {:type :boolean  :required true
                       :doc "Header comment match OR configurable exclusion glob"}
  :file/package       {:type :string   :required false}
  :file/exports       {:type [:vector :string] :required false}
  :file/imports       {:type [:vector :string] :required false}}

 ;; ── Symbol (§2.27.3) ─────────────────────────────────────────────────────────
 :schemas/symbol
 {:symbol/id           {:type :string   :required true
                        :doc "Commit-scoped. SCIP: scip:<sym>. Fallback: local:{lang}:{path}:{kind}:{name}:{sig-hash}:{lines}"}
  :symbol/key          {:type :string   :required false
                        :doc "Cross-commit logical identity. SCIP minus range. Fallback: {lang}:{fqname}:{kind}"}
  :symbol/kind         {:type :keyword  :required true
                        :enum [:fn :method :class :trait :interface :var :const :type :ns :macro :protocol :multimethod]}
  :symbol/name         {:type :string   :required true}
  :symbol/fqname       {:type :string   :required true}
  :symbol/container-id {:type :string   :required false}
  :symbol/visibility   {:type :keyword  :required true  :enum [:public :private :protected :internal]}
  :symbol/modifiers    {:type #{:keyword} :required false}
  :symbol/range.signature {:type :range :required true}
  :symbol/range.body      {:type :range :required false}
  :symbol/range.doc       {:type :range :required false}}

 ;; ── Edge (§2.27.4) ───────────────────────────────────────────────────────────
 :schemas/edge
 {:edge/type {:type :keyword :required true
              :enum [:import :ref :call :implements :inherits :tests :owns :type-of :member-of]}
  :edge/from {:type :map :required true :doc "{:file/path ...} or {:symbol/id ...}"}
  :edge/to   {:type :map :required true :doc "{:file/path ...} or {:symbol/id ...}"}}

 ;; ── Coverage (§2.27.7) ───────────────────────────────────────────────────────
 :schemas/coverage
 {:coverage/symbols? {:type :boolean :required true}
  :coverage/scip?    {:type :boolean :required true}
  :coverage/lsif?    {:type :boolean :required true}
  :coverage/calls?   {:type :keyword :required true :enum [:none :approx :precise]}
  :coverage/refs?    {:type :keyword :required true :enum [:none :approx :precise]}}

 ;; ── Repo Index (§2.27) ───────────────────────────────────────────────────────
 :schemas/repo-index
 {:repo-index/schema-version {:type :string :required true :const "1.0"}
  :repo/id              {:type :string   :required true}
  :repo/vcs             {:type :keyword  :required true :const :git}
  :repo/default-branch  {:type :string   :required true}
  :revision/commit-sha  {:type :string   :required true}
  :revision/tree-sha    {:type :string   :required true}
  :revision/parents     {:type [:vector :string] :required true}
  :revision/indexed-at  {:type :inst     :required true}
  :repo-index/files     {:type [:vector :file-record]  :required true}
  :repo-index/symbols   {:type [:vector :symbol]       :required false :doc "By coverage"}
  :repo-index/edges     {:type [:vector :edge]         :required false :doc "By coverage"}
  :repo-index/search    {:type :search-config          :required true  :doc "At least lexical"}
  :repo-index/repo-map  {:type :repo-map-config        :required true}
  :repo-index/coverage  {:type :coverage               :required true}}

 ;; ── Why Record (§2.28.5) ─────────────────────────────────────────────────────
 :schemas/why-record
 {:why/reason {:type :keyword :required true
               :enum [:search-match :graph-nav :manual-request :dependency :test-failure :policy-rule]}
  :why/query  {:type :string :required false}
  :why/score  {:type :double :required false}
  :why/note   {:type :string :required false}}

 ;; ── Citation (§2.28.4) ───────────────────────────────────────────────────────
 :schemas/citation
 {:cite/use   {:type :keyword :required true
               :enum [:edit-target :evidence :justification :novel-code :synthesis :policy-output]}
  :cite/range {:type :range   :required false :doc "Required for edit-target, evidence, justification"}
  :cite/note  {:type :string  :required false :doc "Required for novel-code, synthesis"}}

 ;; ── Constraint Envelope (§2.28.6) ────────────────────────────────────────────
 :schemas/constraint-envelope
 {:limits/max-open-calls            {:type :int :required true}
  :limits/max-total-snippet-tokens  {:type :int :required true}
  :limits/max-distinct-files-opened {:type :int :required true}
  :limits/max-search-calls          {:type :int :required true}
  :limits/max-search-preview-tokens {:type :int :required true}
  :limits/max-lines-per-open        {:type :int :required true :doc "Hard cap per repo.open call"}
  :limits/max-bytes-per-open        {:type :int :required true :doc "Hard cap per repo.open call"}}

 ;; ── Policy Envelope (§2.28.7) ────────────────────────────────────────────────
 :schemas/policy-envelope
 {:policy/budget-profile    {:type :keyword :required true}
  :policy/on-exhaustion     {:type :keyword :required true :enum [:fail-closed :request-escalation]}
  :policy/escalation-target {:type :string  :required false}}

 ;; ── Context Pack (§2.28) ─────────────────────────────────────────────────────
 :schemas/context-pack
 {:context-pack/schema-version {:type :string :required true :const "1.0"}
  :repo/id              {:type :string  :required true}
  :revision/commit-sha  {:type :string  :required true}
  :task/id              {:type :string  :required true}
  :context/built-at     {:type :inst    :required true}
  :context/repo-map-slice {:type :repo-map-slice :required true}
  :context/symbols      {:type [:vector :context-symbol]  :required false}
  :context/snippets     {:type [:vector :context-snippet] :required false}
  :context/citations    {:type [:vector :citation]        :required false}
  :context/constraints  {:type :constraint-envelope       :required true}
  :context/policy       {:type :policy-envelope           :required true}
  :context/audit        {:type :audit-record              :required true}}

 ;; ── Tool Contract (§2.30) ────────────────────────────────────────────────────
 :tools/agent-facing
 [{:tool/id :repo.index-status
   :tool/args {:repo/id :string :revision/commit-sha :string}
   :tool/returns {:index/ready? :boolean :schema/version :string :coverage :map}}
  {:tool/id :repo.map
   :tool/args {:repo/id :string :revision/commit-sha :string
               :query {:optional :string}
               :budget/profile {:optional :keyword}
               :budget/max-tokens {:optional :int}}
   :tool/returns :context/repo-map-slice}
  {:tool/id :repo.search-lex
   :tool/args {:repo/id :string :revision/commit-sha :string
               :query :string :filters {:optional :map}}
   :tool/returns {:hits [:vector {:hit/path :string :hit/line :int
                                  :hit/preview :string :hit/score :double}]}}
  {:tool/id :repo.search-sem
   :tool/args {:repo/id :string :revision/commit-sha :string
               :query :string :filters {:optional :map}}
   :tool/returns {:items [:vector {:item/kind [:enum :symbol :range :doc]
                                   :symbol/id {:optional :string}
                                   :range {:optional :map}
                                   :item/score :double
                                   :item/why :string}]}}
  {:tool/id :repo.symbol
   :tool/args {:repo/id :string :revision/commit-sha :string
               :symbol/id :string :include/body? {:optional :boolean}}
   :tool/returns :symbol/record}
  {:tool/id :repo.open
   :tool/args {:repo/id :string :revision/commit-sha :string
               :range/path :string :range/start-line :int :range/end-line :int}
   :tool/returns {:snippet/range :map :snippet/content :string}
   :tool/guardrails {:max-lines-default 200 :max-bytes-default 51200
                     :reject-full-file-when-symbol-exists true}}
  ;; graph nav (require coverage)
  {:tool/id :nav.def
   :tool/args {:repo/id :string :revision/commit-sha :string :symbol/id :string}
   :tool/returns {:symbol/id :string}
   :tool/requires-coverage [:scip :lsif]}
  {:tool/id :nav.refs
   :tool/args {:repo/id :string :revision/commit-sha :string
               :symbol/id :string :limit {:optional :int}}
   :tool/returns {:refs [:vector {:ref/kind [:enum :range :symbol]
                                  :symbol/id {:optional :string}
                                  :range {:optional :map}}]}
   :tool/requires-coverage [:refs]}
  {:tool/id :nav.impls
   :tool/args {:repo/id :string :revision/commit-sha :string :symbol/id :string}
   :tool/returns {:impls [:vector {:symbol/id :string}]}
   :tool/requires-coverage [:scip :lsif]}
  {:tool/id :nav.calls
   :tool/args {:repo/id :string :revision/commit-sha :string
               :symbol/id :string
               :direction {:optional [:enum :in :out]}
               :limit {:optional :int}}
   :tool/returns {:calls [:vector {:symbol/id :string}]}
   :tool/requires-coverage [:calls]}]

 :tools/orchestrator-only
 [{:tool/id :context.build
   :tool/args {:task/id :string :repo/id :string :revision/commit-sha :string
               :query :string :budget/profile :keyword}
   :tool/returns :context/pack}
  {:tool/id :context.extend
   :tool/args {:task/id :string
               :request {:req/type :keyword :req/args :map}
               :budget/delta {:optional :map}}
   :tool/returns {:context/patch :map}}
  {:tool/id :context.audit
   :tool/args {:task/id :string}
   :tool/returns {:audit/open-calls :int :audit/snippet-tokens :int
                  :audit/search-calls :int :audit/search-preview-tokens :int
                  :audit/dedupe-ratio :double :audit/sources [:vector :map]}}]

 ;; ── Default budgets by workflow phase (§2.30.5) ──────────────────────────────
 :defaults/budgets-by-phase
 {:plan      {:limits/max-open-calls 2  :limits/max-total-snippet-tokens 1200
              :limits/max-distinct-files-opened 4  :limits/max-search-calls 6
              :limits/max-search-preview-tokens 800
              :limits/max-lines-per-open 200  :limits/max-bytes-per-open 51200}
  :implement {:limits/max-open-calls 8  :limits/max-total-snippet-tokens 3500
              :limits/max-distinct-files-opened 10  :limits/max-search-calls 12
              :limits/max-search-preview-tokens 1500
              :limits/max-lines-per-open 200  :limits/max-bytes-per-open 51200}
  :test      {:limits/max-open-calls 5  :limits/max-total-snippet-tokens 2200
              :limits/max-distinct-files-opened 8  :limits/max-search-calls 8
              :limits/max-search-preview-tokens 1000
              :limits/max-lines-per-open 200  :limits/max-bytes-per-open 51200}
  :review    {:limits/max-open-calls 6  :limits/max-total-snippet-tokens 2800
              :limits/max-distinct-files-opened 12  :limits/max-search-calls 10
              :limits/max-search-preview-tokens 1200
              :limits/max-lines-per-open 200  :limits/max-bytes-per-open 51200}}}
